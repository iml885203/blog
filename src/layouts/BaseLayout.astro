---
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';

export interface Props {
  title: string;
  description?: string;
  cover?: string;
  canonicalUrl?: string;
  ogType?: 'website' | 'article';
  publishedTime?: Date;
  tags?: string[];
  author?: string;
  jsonLd?: string;
  jsonLd2?: string;
}

const { title, description, cover, canonicalUrl, ogType = 'website', publishedTime, tags, author = 'Logan', jsonLd, jsonLd2 } = Astro.props;
const siteTitle = 'Logan 的隨手筆記';
const fullTitle = title === siteTitle ? title : `${title} | ${siteTitle}`;
const siteUrl = 'https://blog.dotw.me';
const canonical = canonicalUrl ?? new URL(Astro.url.pathname, siteUrl).toString();
const ogImage = cover ?? `${siteUrl}/og-default.png`;
---

<!doctype html>
<html lang="zh-TW">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{fullTitle}</title>
    {description && <meta name="description" content={description} />}
    <link rel="canonical" href={canonical} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <!-- OG / Twitter -->
    <meta property="og:site_name" content={siteTitle} />
    <meta property="og:locale" content="zh_TW" />
    <meta property="og:title" content={fullTitle} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content={ogType} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    {ogType === 'article' && publishedTime && (
      <meta property="article:published_time" content={publishedTime.toISOString()} />
    )}
    {ogType === 'article' && <meta property="article:author" content={author} />}
    {ogType === 'article' && tags && tags.map((tag) => (
      <meta property="article:tag" content={tag} />
    ))}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    {description && <meta name="twitter:description" content={description} />}
    <meta name="twitter:image" content={ogImage} />

    <!-- Google Fonts: Noto Sans TC -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <!-- JSON-LD Structured Data -->
    {jsonLd && <script type="application/ld+json" set:html={jsonLd} />}
    {jsonLd2 && <script type="application/ld+json" set:html={jsonLd2} />}

    <!-- View Transitions -->
    <ClientRouter fallback="animate" />

    <!-- Dark mode init: prevent flash -->
    <script is:inline>
      (function () {
        const stored = localStorage.getItem('theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        if (stored === 'dark' || (!stored && prefersDark)) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-GY9ZZHZSBY"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-GY9ZZHZSBY');
    </script>
  </head>

  <body class="bg-[#FAFAFA] dark:bg-[#111111] text-gray-900 dark:text-gray-100 min-h-screen transition-colors duration-200 ambient-light">
    <!-- Noise texture overlay -->
    <div aria-hidden="true" style="pointer-events:none;position:fixed;inset:0;z-index:9998;opacity:0.025;background-image:url(&quot;data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E&quot;);background-size:128px 128px;"></div>

    <!-- Navbar -->
    <header class="sticky top-0 z-50 border-b border-gray-200 dark:border-gray-800 bg-white/70 dark:bg-[#111111]/70 backdrop-blur-xl">
      <nav class="max-w-5xl mx-auto px-4 h-14 flex items-center justify-between">
        <a
          href="/"
          class="text-lg font-bold brand-gradient hover:opacity-80 transition-opacity"
        >
          Logan 的隨手筆記
        </a>

        <div class="flex items-center gap-4">
          <!-- Nav links -->
          <div class="hidden sm:flex items-center gap-1 text-sm">
            {[
              { href: '/archives', label: '文章' },
              { href: '/categories', label: '分類' },
              { href: '/tags', label: '標籤' },
              { href: '/about', label: '關於' },
            ].map(({ href, label }) => {
              const isActive = Astro.url.pathname === href || Astro.url.pathname.startsWith(href + '/');
              return (
                <a
                  href={href}
                  class={`px-3 py-1.5 rounded-md transition-colors ${
                    isActive
                      ? 'text-[#42b883] dark:text-[#65cfa0] bg-[#f0faf5] dark:bg-[#42b883]/20 font-medium'
                      : 'text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white hover:bg-gray-100 dark:hover:bg-gray-800'
                  }`}
                >
                  {label}
                </a>
              );
            })}
          </div>

          <!-- Search button -->
          <a
            href="/search"
            aria-label="搜尋"
            class="p-2 rounded-md text-gray-600 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <circle cx="11" cy="11" r="8" />
              <path stroke-linecap="round" d="m21 21-4.35-4.35" />
            </svg>
          </a>



          <!-- Dark mode toggle -->
          <button
            id="theme-toggle"
            aria-label="切換深色模式"
            class="p-2 rounded-md text-gray-600 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors"
          >
            <!-- Sun icon (shown in dark mode) -->
            <svg id="icon-sun" xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" class="hidden dark:block">
              <circle cx="12" cy="12" r="5" />
              <path stroke-linecap="round" d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42" />
            </svg>
            <!-- Moon icon (shown in light mode) -->
            <svg id="icon-moon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" class="block dark:hidden">
              <path stroke-linecap="round" d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
            </svg>
          </button>

          <!-- Mobile menu button -->
          <button
            id="mobile-menu-btn"
            aria-label="選單"
            class="sm:hidden p-2 rounded-md text-gray-600 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </button>
        </div>
      </nav>

      <!-- Mobile menu dropdown -->
      <div
        id="mobile-menu"
        class="sm:hidden border-t border-gray-200 dark:border-gray-800 bg-white dark:bg-[#111111] overflow-hidden max-h-0 transition-[max-height] duration-300 ease-in-out"
      >
        <div class="max-w-5xl mx-auto px-4 py-2 flex flex-col">
          <a href="/archives" class="py-3 px-2 text-base text-gray-700 dark:text-gray-300 hover:text-[#42b883] dark:hover:text-[#65cfa0] transition-colors border-b border-gray-100 dark:border-gray-800">文章</a>
          <a href="/categories" class="py-3 px-2 text-base text-gray-700 dark:text-gray-300 hover:text-[#42b883] dark:hover:text-[#65cfa0] transition-colors border-b border-gray-100 dark:border-gray-800">分類</a>
          <a href="/tags" class="py-3 px-2 text-base text-gray-700 dark:text-gray-300 hover:text-[#42b883] dark:hover:text-[#65cfa0] transition-colors border-b border-gray-100 dark:border-gray-800">標籤</a>
          <a href="/about" class="py-3 px-2 text-base text-gray-700 dark:text-gray-300 hover:text-[#42b883] dark:hover:text-[#65cfa0] transition-colors">關於</a>
        </div>
      </div>
    </header>

    <!-- Main content -->
    <main class="max-w-5xl mx-auto px-4 py-8" data-pagefind-body>
      <slot />
    </main>

    <!-- Footer -->
    <div class="footer-divider max-w-5xl mx-auto mt-16"></div>
    <footer class="mt-0">
      <div class="max-w-5xl mx-auto px-4 py-8 text-center text-sm text-gray-500 dark:text-gray-400">
        <p>
          © {new Date().getFullYear()} Logan ·
          <a href="/atom.xml" class="hover:text-gray-700 dark:hover:text-gray-200 transition-colors ml-1">RSS</a> ·
          <a href="/sitemap-index.xml" class="hover:text-gray-700 dark:hover:text-gray-200 transition-colors ml-1">Sitemap</a>
        </p>
      </div>
    </footer>

    <!-- Dark mode + mobile menu JS (is:inline = runs immediately, no Astro lifecycle delay) -->
    <script is:inline>
      function initBaseLayout() {
        // Dark mode toggle
        var themeToggle = document.getElementById('theme-toggle');
        if (themeToggle && !themeToggle._darkInit) {
          themeToggle._darkInit = true;
          themeToggle.addEventListener('click', function() {
            var isDark = document.documentElement.classList.contains('dark');
            if (isDark) {
              document.documentElement.classList.remove('dark');
              localStorage.setItem('theme', 'light');
            } else {
              document.documentElement.classList.add('dark');
              localStorage.setItem('theme', 'dark');
            }
          });
        }

        // Mobile menu toggle (slide animation via max-height)
        var mobileMenuBtn = document.getElementById('mobile-menu-btn');
        var mobileMenu = document.getElementById('mobile-menu');
        if (mobileMenuBtn && mobileMenu && !mobileMenuBtn._menuInit) {
          mobileMenuBtn._menuInit = true;
          var menuOpen = false;
          mobileMenuBtn.addEventListener('click', function() {
            menuOpen = !menuOpen;
            mobileMenu.style.maxHeight = menuOpen ? mobileMenu.scrollHeight + 'px' : '0px';
          });
        }
      }
      initBaseLayout();
      document.addEventListener('astro:after-swap', function() {
        // Re-apply dark mode class after swap
        const stored = localStorage.getItem('theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        if (stored === 'dark' || (!stored && prefersDark)) {
          document.documentElement.classList.add('dark');
        } else {
          document.documentElement.classList.remove('dark');
        }
        // Scroll to top on page navigation
        window.scrollTo({ top: 0, behavior: 'instant' });
      });
      document.addEventListener('astro:page-load', initBaseLayout);
    </script>
  </body>
</html>
