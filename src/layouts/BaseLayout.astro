---
import { ClientRouter } from 'astro:transitions';
import LoadingIndicator from 'astro-loading-indicator/component';
import { Icon } from 'astro-icon/components';
import '@/styles/global.css';
import { getLangFromUrl, useTranslations, getAlternateLocaleUrl, getLocalePath } from '@/i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const alternateLang = lang === 'zh-TW' ? 'en' : 'zh-TW';

export interface Props {
  title: string;
  description?: string;
  cover?: string;
  canonicalUrl?: string;
  ogType?: 'website' | 'article';
  publishedTime?: Date;
  tags?: string[];
  author?: string;
  jsonLd?: string;
  jsonLd2?: string;
}

const {
  title,
  description,
  cover,
  canonicalUrl,
  ogType = 'website',
  publishedTime,
  tags,
  author = 'Logan',
  jsonLd,
  jsonLd2,
} = Astro.props;
const siteTitle = t('site.title');
const fullTitle = title === siteTitle ? title : `${title} | ${siteTitle}`;
const siteUrl = 'https://blog.dotw.me';
const canonical = canonicalUrl ?? new URL(Astro.url.pathname, siteUrl).toString();
const ogImage = cover ?? `${siteUrl}/og-default.png`;

const navItems = [
  { href: getLocalePath('/archives', lang), label: t('nav.articles'), icon: 'lucide:newspaper' },
  { href: getLocalePath('/categories', lang), label: t('nav.categories'), icon: 'lucide:folder' },
  { href: getLocalePath('/tags', lang), label: t('nav.tags'), icon: 'lucide:tag' },
  { href: getLocalePath('/about', lang), label: t('nav.about'), icon: 'lucide:user' },
];
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{fullTitle}</title>
    {description && <meta name="description" content={description} />}
    <link rel="canonical" href={canonical} />
    <link
      rel="alternate"
      hreflang="zh-TW"
      href={new URL(getAlternateLocaleUrl(Astro.url, 'zh-TW'), siteUrl).toString()}
    />
    <link rel="alternate" hreflang="en" href={new URL(getAlternateLocaleUrl(Astro.url, 'en'), siteUrl).toString()} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <!-- OG / Twitter -->
    <meta property="og:site_name" content={siteTitle} />
    <meta property="og:locale" content={lang === 'zh-TW' ? 'zh_TW' : 'en_US'} />
    <meta property="og:title" content={fullTitle} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content={ogType} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    {
      ogType === 'article' && publishedTime && (
        <meta property="article:published_time" content={publishedTime.toISOString()} />
      )
    }
    {ogType === 'article' && <meta property="article:author" content={author} />}
    {ogType === 'article' && tags && tags.map((tag) => <meta property="article:tag" content={tag} />)}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    {description && <meta name="twitter:description" content={description} />}
    <meta name="twitter:image" content={ogImage} />

    <!-- Google Fonts: Noto Sans TC -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <!-- JSON-LD Structured Data -->
    {jsonLd && <script type="application/ld+json" set:html={jsonLd} />}
    {jsonLd2 && <script type="application/ld+json" set:html={jsonLd2} />}

    <!-- View Transitions -->
    <ClientRouter fallback="animate" />
    <LoadingIndicator color="#42b883" height="2px" />

    <!-- Dark mode init: prevent flash -->
    <script is:inline>
      (function () {
        const stored = localStorage.getItem('theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        if (stored === 'dark' || (!stored && prefersDark)) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-GY9ZZHZSBY"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag('js', new Date());
      gtag('config', 'G-GY9ZZHZSBY');
    </script>
  </head>

  <body
    class="bg-[#FAFAFA] dark:bg-[#111111] text-gray-900 dark:text-gray-100 min-h-screen transition-colors duration-200 ambient-light"
  >
    <!-- Noise texture overlay -->
    <div
      aria-hidden="true"
      style="pointer-events:none;position:fixed;inset:0;z-index:9998;opacity:0.025;background-image:url(&quot;data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E&quot;);background-size:128px 128px;"
    >
    </div>

    <!-- Navbar -->
    <header
      class="sticky top-0 z-50 border-b border-gray-200 dark:border-gray-800 bg-white/70 dark:bg-[#111111]/70 backdrop-blur-xl transition-colors header-vt"
    >
      <nav class="max-w-5xl mx-auto px-4 h-14 flex items-center justify-between">
        <a href={getLocalePath('/', lang)} class="text-lg font-bold brand-gradient hover:opacity-80 transition-opacity"
          >{siteTitle}</a
        >

        <div class="flex items-center gap-4">
          <!-- Nav links -->
          <div class="hidden sm:flex items-center gap-1 text-sm">
            {
              navItems.map(({ href, label }) => {
                const isActive = Astro.url.pathname === href || Astro.url.pathname.startsWith(href + '/');
                return (
                  <a
                    href={href}
                    class={`px-3 py-1.5 rounded-md transition-colors ${
                      isActive
                        ? 'text-[#42b883] dark:text-[#65cfa0] bg-[#f0faf5] dark:bg-[#42b883]/20 font-medium'
                        : 'text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white hover:bg-gray-100 dark:hover:bg-gray-800'
                    }`}
                  >
                    {label}
                  </a>
                );
              })
            }
          </div>

          <!-- Search button -->
          <button
            id="search-btn"
            aria-label={t('aria.search')}
            class="p-2 rounded-md text-gray-600 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors"
          >
            <Icon name="lucide:search" class="w-[18px] h-[18px]" />
          </button>

          <!-- Language switcher -->
          <a
            href={getAlternateLocaleUrl(Astro.url, alternateLang)}
            class="p-2 rounded-md text-gray-600 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors"
            aria-label={alternateLang === 'en' ? 'Switch to English' : '切換為中文'}
          >
            <Icon name="lucide:languages" class="w-[18px] h-[18px]" />
          </a>

          <!-- Dark mode toggle -->
          <button
            id="theme-toggle"
            aria-label={t('aria.toggleDarkMode')}
            class="p-2 rounded-md text-gray-600 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors"
          >
            <!-- Sun icon (shown in dark mode) -->
            <span id="icon-sun" class="hidden dark:block"><Icon name="lucide:sun" class="w-[18px] h-[18px]" /></span>
            <!-- Moon icon (shown in light mode) -->
            <span id="icon-moon" class="block dark:hidden"><Icon name="lucide:moon" class="w-[18px] h-[18px]" /></span>
          </button>

          <!-- Mobile menu button -->
          <button
            id="mobile-menu-btn"
            aria-label={t('aria.menu')}
            class="sm:hidden p-2 rounded-md text-gray-600 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors"
          >
            <div class="w-[18px] h-[18px] relative">
              <span
                class="menu-line absolute left-[2px] right-[2px] h-[1.5px] bg-current rounded-full top-[4px] transition-[transform,opacity] duration-300 origin-center"
              ></span>
              <span
                class="menu-line absolute left-[2px] right-[2px] h-[1.5px] bg-current rounded-full top-[8.5px] transition-[transform,opacity] duration-300 origin-center"
              ></span>
              <span
                class="menu-line absolute left-[2px] right-[2px] h-[1.5px] bg-current rounded-full top-[13px] transition-[transform,opacity] duration-300 origin-center"
              ></span>
            </div>
          </button>
        </div>
      </nav>
    </header>

    <!-- Mobile menu overlay -->
    <div
      id="mobile-menu-overlay"
      class="sm:hidden fixed inset-0 top-14 z-40 bg-black/20 backdrop-blur-md opacity-0 pointer-events-none transition-opacity duration-300"
    >
    </div>

    <!-- Mobile menu panel -->
    <div
      id="mobile-menu"
      class="sm:hidden fixed left-0 right-0 top-14 z-50 bg-white/50 dark:bg-[#111111]/50 backdrop-blur-2xl saturate-150 border-b border-gray-200/50 dark:border-gray-700/50 shadow-xl shadow-black/5 translate-y-[-10px] opacity-0 pointer-events-none transition-[opacity,transform] duration-300 ease-out"
    >
      <div class="max-w-5xl mx-auto px-5 py-4 flex flex-col gap-1">
        {
          navItems.map(({ href, label, icon }) => {
            const isActive = Astro.url.pathname === href || Astro.url.pathname.startsWith(href + '/');
            return (
              <a
                href={href}
                class={`flex items-center gap-3 px-4 py-3 rounded-xl text-base font-medium transition-colors ${
                  isActive
                    ? 'text-[#42b883] dark:text-[#65cfa0] bg-[#f0faf5] dark:bg-[#42b883]/15'
                    : 'text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-800/60'
                }`}
              >
                <Icon name={icon} class="w-[18px] h-[18px] flex-shrink-0 opacity-60" />
                {label}
              </a>
            );
          })
        }
      </div>
    </div>

    <!-- Main content -->
    <main class="max-w-5xl mx-auto px-4 py-4 sm:py-8">
      <slot />
    </main>

    <!-- Footer -->
    <div class="footer-divider max-w-5xl mx-auto mt-8 sm:mt-16"></div>
    <footer class="mt-0">
      <div class="max-w-5xl mx-auto px-4 py-4 sm:py-8 text-center text-sm text-gray-500 dark:text-gray-400">
        <p>
          © {new Date().getFullYear()} Logan ·
          <a href="/atom.xml" class="hover:text-gray-700 dark:hover:text-gray-200 transition-colors ml-1">RSS</a> ·
          <a href="/sitemap-index.xml" class="hover:text-gray-700 dark:hover:text-gray-200 transition-colors ml-1"
            >Sitemap</a
          >
        </p>
      </div>
    </footer>

    <!-- Search modal (Cmd+K) -->
    <div
      id="search-modal-overlay"
      class="fixed inset-0 z-[100] bg-black/50 backdrop-blur-sm opacity-0 pointer-events-none transition-opacity duration-200"
    >
    </div>
    <div
      id="search-modal"
      class="fixed inset-0 z-[101] flex items-start justify-center pt-[15vh] px-4 opacity-0 pointer-events-none transition-[opacity,transform] duration-200 translate-y-[-10px]"
    >
      <div
        class="w-full max-w-xl max-h-[80vh] bg-white dark:bg-[#1a1a1a] rounded-2xl shadow-2xl border border-gray-200 dark:border-gray-700 overflow-hidden min-w-0 flex flex-col"
      >
        <div class="flex items-center gap-3 px-4 py-3 border-b border-gray-200 dark:border-gray-700 min-w-0">
          <Icon name="lucide:search" class="w-[18px] h-[18px] text-gray-400 flex-shrink-0" />
          <input
            id="search-modal-input"
            type="text"
            placeholder={t('search.placeholder')}
            class="flex-1 min-w-0 bg-transparent text-gray-900 dark:text-white text-base placeholder:text-gray-400"
            style="outline: none; box-shadow: none;"
            autocomplete="off"
          />
          <kbd
            class="hidden sm:inline-flex text-xs text-gray-400 border border-gray-300 dark:border-gray-600 rounded px-1.5 py-0.5"
            >ESC</kbd
          >
        </div>
        <div
          id="search-modal-results"
          class="flex-1 min-h-0 overflow-y-auto p-2 [&_mark]:bg-[#42b883]/15 [&_mark]:text-[#42b883] [&_mark]:rounded-sm [&_mark]:px-0.5 dark:[&_mark]:bg-[#65cfa0]/15 dark:[&_mark]:text-[#65cfa0]"
          data-empty-text={t('search.empty')}
          data-no-results={t('search.noResults')}
          data-view-all={t('search.viewAll', { count: '{count}' })}
        >
          <div class="px-3 py-8 text-center text-sm text-gray-400">{t('search.empty')}</div>
        </div>
      </div>
    </div>

    <!-- Dark mode + mobile menu JS (is:inline = runs immediately, no Astro lifecycle delay) -->
    <script is:inline>
      function initBaseLayout() {
        // Dark mode toggle
        var themeToggle = document.getElementById('theme-toggle');
        if (themeToggle && !themeToggle._darkInit) {
          themeToggle._darkInit = true;
          themeToggle.addEventListener('click', function (e) {
            var isDark = document.documentElement.classList.contains('dark');

            function toggle() {
              if (isDark) {
                document.documentElement.classList.remove('dark');
                localStorage.setItem('theme', 'light');
              } else {
                document.documentElement.classList.add('dark');
                localStorage.setItem('theme', 'dark');
              }
            }

            if (!document.startViewTransition || window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
              toggle();
              return;
            }

            var x = e.clientX;
            var y = e.clientY;
            var maxRadius = Math.hypot(Math.max(x, window.innerWidth - x), Math.max(y, window.innerHeight - y));

            var root = document.documentElement;
            root.style.viewTransitionName = 'toggle-color-scheme';

            var transition = document.startViewTransition(toggle);

            transition.ready.then(function () {
              root.animate(
                {
                  clipPath: [
                    'circle(0px at ' + x + 'px ' + y + 'px)',
                    'circle(' + maxRadius + 'px at ' + x + 'px ' + y + 'px)',
                  ],
                },
                {
                  duration: 500,
                  easing: 'cubic-bezier(0.4, 0, 0.2, 1)',
                  fill: 'both',
                  pseudoElement: '::view-transition-new(toggle-color-scheme)',
                },
              );
            });

            transition.finished.finally(function () {
              root.style.viewTransitionName = '';
            });
          });
        }

        // Mobile menu toggle
        var mobileMenuBtn = document.getElementById('mobile-menu-btn');
        var mobileMenu = document.getElementById('mobile-menu');
        var mobileOverlay = document.getElementById('mobile-menu-overlay');
        if (mobileMenuBtn && mobileMenu && !mobileMenuBtn._menuInit) {
          mobileMenuBtn._menuInit = true;
          var menuOpen = false;
          var closeTimer = null;

          function toggleMenu(open) {
            menuOpen = typeof open === 'boolean' ? open : !menuOpen;
            if (closeTimer) {
              clearTimeout(closeTimer);
              closeTimer = null;
            }
            if (menuOpen) {
              mobileMenu.classList.remove('opacity-0', 'translate-y-[-10px]', 'pointer-events-none');
              mobileMenu.classList.add('opacity-100', 'translate-y-0');
              mobileOverlay.classList.remove('opacity-0', 'pointer-events-none');
              mobileOverlay.classList.add('opacity-100');
              mobileMenuBtn.classList.add('menu-open');
              document.body.style.overflow = 'hidden';
            } else {
              mobileMenu.classList.add('opacity-0', 'pointer-events-none');
              mobileMenu.classList.remove('opacity-100');
              mobileOverlay.classList.add('opacity-0', 'pointer-events-none');
              mobileOverlay.classList.remove('opacity-100');
              mobileMenuBtn.classList.remove('menu-open');
              closeTimer = setTimeout(function () {
                closeTimer = null;
                document.body.style.overflow = '';
                mobileMenu.classList.add('translate-y-[-10px]');
                mobileMenu.classList.remove('translate-y-0');
              }, 300);
            }
          }

          mobileMenuBtn.addEventListener('click', function () {
            toggleMenu();
          });
          mobileOverlay.addEventListener('click', function () {
            toggleMenu(false);
          });
          mobileMenu.querySelectorAll('a').forEach(function (link) {
            link.addEventListener('click', function () {
              toggleMenu(false);
            });
          });
        }
      }
      initBaseLayout();
      if (!window._baseLayoutInit) {
        window._baseLayoutInit = true;
        document.addEventListener('astro:after-swap', function () {
          var stored = localStorage.getItem('theme');
          var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          if (stored === 'dark' || (!stored && prefersDark)) {
            document.documentElement.classList.add('dark');
          } else {
            document.documentElement.classList.remove('dark');
          }
          window.scrollTo({ top: 0, behavior: 'instant' });
        });
        document.addEventListener('astro:page-load', initBaseLayout);
      }
    </script>

    <!-- Search modal JS -->
    <script is:inline>
      var _pagefind = null;

      function _loadPagefind() {
        if (_pagefind) return Promise.resolve(_pagefind);
        return import('/pagefind/pagefind.js').then(function (pf) {
          _pagefind = pf;
          return pf.init().then(function () {
            return pf;
          });
        });
      }

      function initSearchModal() {
        var overlay = document.getElementById('search-modal-overlay');
        var modal = document.getElementById('search-modal');
        var input = document.getElementById('search-modal-input');
        var results = document.getElementById('search-modal-results');
        var searchBtn = document.getElementById('search-btn');
        if (!overlay || !modal || !input || !results || !searchBtn) return;
        if (searchBtn._searchInit) return;
        searchBtn._searchInit = true;

        var isOpen = false;

        function renderEmpty(text) {
          results.innerHTML = '';
          var div = document.createElement('div');
          div.className = 'px-3 py-8 text-center text-sm text-gray-400';
          div.textContent = text;
          results.appendChild(div);
        }

        function open() {
          if (isOpen) return;
          isOpen = true;
          overlay.classList.remove('opacity-0', 'pointer-events-none');
          overlay.classList.add('opacity-100');
          modal.classList.remove('opacity-0', 'pointer-events-none', 'translate-y-[-10px]');
          modal.classList.add('opacity-100', 'translate-y-0');
          document.body.style.overflow = 'hidden';
          input.focus();
        }

        function close() {
          if (!isOpen) return;
          isOpen = false;
          overlay.classList.add('opacity-0', 'pointer-events-none');
          overlay.classList.remove('opacity-100');
          modal.classList.add('opacity-0', 'pointer-events-none', 'translate-y-[-10px]');
          modal.classList.remove('opacity-100', 'translate-y-0');
          document.body.style.overflow = '';
          input.value = '';
          renderEmpty(results.dataset.emptyText || 'Type to search articles');
        }

        // Store open/close on window so the global keydown listener can access current versions
        window._searchOpen = open;
        window._searchClose = close;

        searchBtn.addEventListener('click', open);
        overlay.addEventListener('click', close);
        modal.addEventListener('click', function (e) {
          if (e.target === modal) close();
        });

        // Event delegation for result clicks
        results.addEventListener('click', function (e) {
          var link = e.target.closest('a');
          if (link) close();
        });

        var debounce;
        input.addEventListener('input', function () {
          clearTimeout(debounce);
          debounce = setTimeout(function () {
            var query = input.value.trim();
            if (!query) {
              renderEmpty(results.dataset.emptyText || 'Type to search articles');
              return;
            }

            // Show skeleton loading
            results.innerHTML = '';
            for (var i = 0; i < 3; i++) {
              var skel = document.createElement('div');
              skel.className = 'px-3 py-3';
              skel.innerHTML =
                '<div class="h-4 w-3/4 bg-gray-200 dark:bg-gray-700 rounded animate-pulse"></div>' +
                '<div class="h-3 w-1/2 bg-gray-100 dark:bg-gray-800 rounded animate-pulse mt-2"></div>';
              results.appendChild(skel);
            }

            _loadPagefind()
              .then(function (pf) {
                return pf.search(query);
              })
              .then(function (search) {
                var totalResults = search.results.length;
                return Promise.all(
                  search.results.slice(0, 6).map(function (r) {
                    return r.data();
                  }),
                ).then(function (items) {
                  return { items: items, total: totalResults };
                });
              })
              .then(function (data) {
                var items = data.items;
                var total = data.total;
                if (items.length === 0) {
                  renderEmpty(results.dataset.noResults || 'No articles found');
                  return;
                }

                results.innerHTML = '';
                items.forEach(function (item) {
                  var a = document.createElement('a');
                  a.href = item.url;
                  a.className = 'block px-3 py-3 rounded-xl hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors';

                  var title = document.createElement('div');
                  title.className = 'text-sm font-medium text-gray-900 dark:text-white';
                  title.textContent = (item.meta && item.meta.title) || item.url;

                  var excerpt = document.createElement('div');
                  excerpt.className = 'text-xs text-gray-500 dark:text-gray-400 mt-0.5 line-clamp-1';
                  excerpt.innerHTML = item.excerpt; // Pagefind excerpt contains <mark> tags for highlighting

                  a.appendChild(title);
                  a.appendChild(excerpt);
                  results.appendChild(a);
                });

                if (total > 6) {
                  var more = document.createElement('a');
                  more.href = '/search?q=' + encodeURIComponent(query);
                  more.className =
                    'block px-3 py-3 text-center text-sm text-[#42b883] dark:text-[#65cfa0] hover:underline';
                  more.textContent = (results.dataset.viewAll || 'View all {count} results →').replace(
                    '{count}',
                    total,
                  );
                  more.addEventListener('click', close);
                  results.appendChild(more);
                }
              });
          }, 200);
        });
      }

      initSearchModal();
      if (!window._searchModalInit) {
        window._searchModalInit = true;
        document.addEventListener('keydown', function (e) {
          if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
            e.preventDefault();
            if (window._searchOpen) window._searchOpen();
          }
          if (e.key === 'Escape' && window._searchClose) window._searchClose();
        });
        document.addEventListener('astro:page-load', initSearchModal);
      }
    </script>
  </body>
</html>
