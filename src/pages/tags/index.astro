---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Divider from '@/components/Divider.astro';
import { getLangFromUrl, useTranslations, getLocalePath } from '@/i18n/utils';
import { getLocalizedPosts } from '@/i18n/content';
import { getTagSlug, getTagDisplayName } from '@/i18n/tags';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const allPosts = await getLocalizedPosts(lang);

// Build tag map: tag → posts[]
const tagMap = new Map<string, typeof allPosts>();
for (const post of allPosts) {
  const tags = post.data.tags ?? [];
  for (const tag of tags) {
    if (!tagMap.has(tag)) tagMap.set(tag, []);
    tagMap.get(tag)!.push(post);
  }
}

// Sort tags by post count desc
const tags = [...tagMap.entries()]
  .map(([name, posts]) => ({
    name,
    count: posts.length,
  }))
  .sort((a, b) => b.count - a.count);

const totalPosts = allPosts.length;
const maxCount = tags[0]?.count ?? 1;
---

<BaseLayout title={t('tags.title')} description={t('tags.description', { count: tags.length, posts: totalPosts })}>
  <div class="flex flex-col gap-6 sm:gap-10 slide-enter-content">
    <div>
      <h1 class="text-2xl font-bold text-gray-900 dark:text-white mb-1">{t('tags.title')}</h1>
      <p class="text-gray-500 dark:text-gray-400 text-sm">
        {t('tags.stats', { count: tags.length, posts: totalPosts })}
      </p>
    </div>

    <Divider />

    <nav class="flex flex-wrap items-center justify-center gap-x-3 gap-y-2 py-4" aria-label={t('tags.title')}>
      {
        tags.map(({ name, count }, i) => {
          const weight = count / maxCount;
          return (
            <a
              href={getLocalePath(`/tags/${getTagSlug(name)}/`, lang)}
              class="tag-cloud-item text-gray-700 dark:text-gray-300 hover:text-[#42b883] dark:hover:text-[#65cfa0] transition-[opacity,transform,color] duration-200 inline-block px-1 py-0.5 relative"
              style={`--w: ${weight}; animation-delay: ${i * 10}ms`}
              title={`${getTagDisplayName(name, lang)} (${count})`}
            >
              <span class="relative z-10">#{getTagDisplayName(name, lang)}</span>
            </a>
          );
        })
      }
    </nav>
  </div>
</BaseLayout>

<style>
  @media (prefers-reduced-motion: no-preference) {
    .tag-cloud-item {
      animation: tag-enter 0.4s ease both;
    }
  }

  @keyframes tag-enter {
    from {
      opacity: 0;
      transform: translateY(8px) scale(0.95);
    }
    to {
      opacity: calc(0.45 + var(--w) * 0.55);
      transform: translateY(0) scale(1);
    }
  }

  .tag-cloud-item {
    font-size: calc(0.85rem + var(--w) * 1.4rem);
    opacity: calc(0.45 + var(--w) * 0.55);
    font-weight: calc(400 + var(--w) * 300);
  }

  .tag-cloud-item::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 2px;
    background: #42b883;
    border-radius: 1px;
    transition: width 0.25s ease;
  }

  .tag-cloud-item:hover {
    opacity: 1;
    transform: scale(1.05);
  }

  .tag-cloud-item:hover::after {
    width: 100%;
  }
</style>
