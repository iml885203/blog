---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const allPosts = await getCollection('posts', ({ data }) => !data.draft);

// Build tag map: tag → posts[]
const tagMap = new Map<string, typeof allPosts>();
for (const post of allPosts) {
  const tags = post.data.tags ?? [];
  for (const tag of tags) {
    if (!tagMap.has(tag)) tagMap.set(tag, []);
    tagMap.get(tag)!.push(post);
  }
}

// Sort tags by post count desc
const tags = [...tagMap.entries()]
  .map(([name, posts]) => ({
    name,
    count: posts.length,
  }))
  .sort((a, b) => b.count - a.count);

const totalPosts = allPosts.length;
---

<BaseLayout
  title="標籤"
  description={`瀏覽所有 ${tags.length} 個標籤，共 ${totalPosts} 篇文章。`}
>
  <!-- Page header -->
  <div class="mb-10 pb-8 border-b border-gray-200 dark:border-gray-800">
    <h1 class="text-2xl font-bold text-gray-900 dark:text-white mb-1">標籤</h1>
    <p class="text-gray-500 dark:text-gray-400 text-sm">
      共 {tags.length} 個標籤 · {totalPosts} 篇文章
    </p>
  </div>

  <!-- Tag cloud -->
  <div class="flex flex-wrap gap-3">
    {tags.map(({ name, count }) => {
      // Discrete size classes by post count
      const sizeClass =
        count >= 7
          ? 'text-xl font-semibold'
          : count >= 4
          ? 'text-lg font-medium'
          : count >= 2
          ? 'text-base font-medium'
          : 'text-sm font-normal';

      return (
        <a
          href={`/tags/${encodeURIComponent(name)}/`}
          class={`group inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full border border-gray-200 dark:border-gray-700 hover:border-[#65cfa0] dark:hover:border-[#42b883] hover:bg-[#f0faf5]/50 dark:hover:bg-[#42b883]/10 transition-all duration-200 ${sizeClass}`}
        >
          <span class="text-gray-700 dark:text-gray-300 group-hover:text-[#42b883] dark:group-hover:text-[#65cfa0] transition-colors">
            #{name}
          </span>
          <span class="text-xs text-gray-400 dark:text-gray-500 group-hover:text-[#42b883] dark:group-hover:text-[#42b883] transition-colors">
            {count}
          </span>
        </a>
      );
    })}
  </div>
</BaseLayout>
