---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Divider from '@/components/Divider.astro';
import CompactPostCard from '@/components/CompactPostCard.astro';
import { getLangFromUrl, useTranslations, getLocalePath } from '@/i18n/utils';
import { getLocalizedPosts } from '@/i18n/content';
import { getTagSlug, getTagDisplayName } from '@/i18n/tags';

export async function getStaticPaths() {
  const allPosts = await getLocalizedPosts('zh-TW');

  // Collect all unique tags
  const tagSet = new Set<string>();
  for (const post of allPosts) {
    for (const tag of post.data.tags ?? []) {
      tagSet.add(tag);
    }
  }

  return [...tagSet].map((tag) => {
    const posts = allPosts
      .filter((p) => (p.data.tags ?? []).includes(tag))
      .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

    return {
      params: { tag: getTagSlug(tag) },
      props: { tag, posts },
    };
  });
}

interface Props {
  tag: string;
  posts: Awaited<ReturnType<typeof getCollection>>;
}

const { tag, posts } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<BaseLayout
  title={`${t('tags.title')}：${getTagDisplayName(tag, lang)}`}
  description={`${getTagDisplayName(tag, lang)} — ${t('tags.totalPosts', { count: posts.length })}`}
>
  <!-- Breadcrumb -->
  <nav class="flex items-center gap-2 text-sm text-gray-500 dark:text-gray-400 mb-8" aria-label={t('aria.breadcrumb')}>
    <a href={getLocalePath('/', lang)} class="hover:text-[#42b883] dark:hover:text-[#65cfa0] transition-colors"
      >{t('common.home')}</a
    >
    <span>/</span>
    <a href={getLocalePath('/tags/', lang)} class="hover:text-[#42b883] dark:hover:text-[#65cfa0] transition-colors"
      >{t('tags.title')}</a
    >
    <span>/</span>
    <span class="text-gray-900 dark:text-white font-medium">{getTagDisplayName(tag, lang)}</span>
  </nav>

  <div class="flex flex-col gap-6 sm:gap-10 slide-enter-content">
    <div>
      <div class="flex items-center gap-3 mb-1">
        <span
          class="bg-[#f0faf5] dark:bg-[#42b883]/30 text-[#42b883] dark:text-[#65cfa0] px-3 py-1 rounded-full text-sm font-semibold"
        >
          #{getTagDisplayName(tag, lang)}
        </span>
      </div>
      <p class="text-gray-500 dark:text-gray-400 text-sm mt-2">{t('tags.totalPosts', { count: posts.length })}</p>
    </div>

    <Divider />

    <div class="space-y-3 sm:space-y-6">
      {posts.map((post) => <CompactPostCard post={post} activeTag={tag} />)}
    </div>

    <Divider />

    <a
      href={getLocalePath('/tags/', lang)}
      class="inline-flex items-center gap-2 text-sm text-gray-500 dark:text-gray-400 hover:text-[#42b883] dark:hover:text-[#65cfa0] transition-colors"
    >
      {t('tags.backToAll')}
    </a>
  </div>
</BaseLayout>
