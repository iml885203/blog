---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { stripMarkdown } from '../../utils/markdown';
import { formatDate } from '../../utils/date';
import { formatDate } from '../../utils/date';

export async function getStaticPaths() {
  const allPosts = await getCollection('posts', ({ data }) => !data.draft);

  // Collect all unique tags
  const tagSet = new Set<string>();
  for (const post of allPosts) {
    for (const tag of post.data.tags ?? []) {
      tagSet.add(tag);
    }
  }

  return [...tagSet].map((tag) => {
    const posts = allPosts
      .filter((p) => (p.data.tags ?? []).includes(tag))
      .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

    return {
      params: { tag },
      props: { tag, posts },
    };
  });
}

interface Props {
  tag: string;
  posts: Awaited<ReturnType<typeof getCollection>>;
}

const { tag, posts } = Astro.props;
---

<BaseLayout
  title={`標籤：${tag}`}
  description={`${tag} 標籤下共 ${posts.length} 篇文章。`}
>
  <!-- Breadcrumb -->
  <nav class="flex items-center gap-2 text-sm text-gray-500 dark:text-gray-400 mb-8" aria-label="麵包屑">
    <a href="/" class="hover:text-[#42b883] dark:hover:text-[#65cfa0] transition-colors">首頁</a>
    <span>/</span>
    <a href="/tags/" class="hover:text-[#42b883] dark:hover:text-[#65cfa0] transition-colors">標籤</a>
    <span>/</span>
    <span class="text-gray-900 dark:text-white font-medium">{tag}</span>
  </nav>

  <!-- Page header -->
  <div class="mb-10 pb-8 border-b border-gray-200 dark:border-gray-800">
    <div class="flex items-center gap-3 mb-1">
      <span class="bg-purple-50 dark:bg-purple-900/30 text-purple-600 dark:text-purple-400 px-3 py-1 rounded-full text-sm font-semibold">
        #{tag}
      </span>
    </div>
    <p class="text-gray-500 dark:text-gray-400 text-sm mt-2">共 {posts.length} 篇文章</p>
  </div>

  <!-- Post list -->
  <div class="space-y-8">
    {posts.map((post) => (
      <article class="group flex gap-5">
        {/* Cover thumbnail */}
        {post.data.cover && (
          <a href={`/${post.id}/`} class="flex-shrink-0 hidden sm:block">
            <div class="w-32 h-20 rounded-lg overflow-hidden bg-gray-100 dark:bg-gray-800">
              <img
                src={post.data.cover}
                alt={post.data.title}
                loading="lazy"
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
              />
            </div>
          </a>
        )}

        {/* Content */}
        <div class="flex-1 min-w-0">
          <div class="flex items-center gap-2 mb-1.5 text-xs text-gray-500 dark:text-gray-400">
            <time datetime={post.data.date.toISOString()}>
              {formatDate(post.data.date)}
            </time>
            {post.data.category && (
              <>
                <span>·</span>
                <a
                  href={`/categories/${encodeURIComponent(post.data.category)}/`}
                  class="hover:text-[#42b883] dark:hover:text-[#65cfa0] transition-colors"
                >
                  {post.data.category}
                </a>
              </>
            )}
          </div>

          <h2 class="text-lg font-semibold text-gray-900 dark:text-white group-hover:text-[#42b883] dark:group-hover:text-[#65cfa0] transition-colors leading-snug mb-1.5">
            <a href={`/${post.id}/`}>{post.data.title}</a>
          </h2>

          {post.data.description && (
            <p class="text-gray-600 dark:text-gray-400 text-sm leading-relaxed line-clamp-2">
              {stripMarkdown(post.data.description)}
            </p>
          )}

          {post.data.tags && post.data.tags.length > 0 && (
            <div class="flex flex-wrap gap-1.5 mt-2">
              {post.data.tags.slice(0, 5).map((t) => (
                <a
                  href={`/tags/${encodeURIComponent(t)}/`}
                  class={`text-xs transition-colors ${
                    t === tag
                      ? 'text-purple-600 dark:text-purple-400 font-medium'
                      : 'text-gray-500 dark:text-gray-400 hover:text-[#42b883] dark:hover:text-[#65cfa0]'
                  }`}
                >
                  #{t}
                </a>
              ))}
            </div>
          )}
        </div>
      </article>
    ))}
  </div>

  <!-- Back link -->
  <div class="mt-12 pt-8 border-t border-gray-200 dark:border-gray-800">
    <a
      href="/tags/"
      class="inline-flex items-center gap-2 text-sm text-gray-500 dark:text-gray-400 hover:text-[#42b883] dark:hover:text-[#65cfa0] transition-colors"
    >
      ← 所有標籤
    </a>
  </div>
</BaseLayout>
