---
import { render } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import AuthorCard from '@/components/AuthorCard.astro';
import CategoryBadge from '@/components/CategoryBadge.astro';
import TableOfContents from '@/components/TableOfContents.astro';
import RelatedPosts from '@/components/RelatedPosts.astro';
import PostNavigation from '@/components/PostNavigation.astro';
import ShareButtons from '@/components/ShareButtons.astro';
import { formatDate } from '@/utils/date';
import Giscus from '@/components/Giscus.astro';
import { stripMarkdown, readingTime } from '@/utils/markdown';
import Divider from '@/components/Divider.astro';
import { Icon } from 'astro-icon/components';
import { getLangFromUrl, useTranslations, getLocalePath } from '@/i18n/utils';
import { getLocalizedPosts, getSlug } from '@/i18n/content';
import { getCategorySlug } from '@/i18n/categories';

export async function getStaticPaths() {
  const posts = await getLocalizedPosts('zh-TW');
  return posts.map((post) => ({
    params: { slug: getSlug(post.id) },
    props: { post },
  }));
}

const { post } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const { Content, headings } = await render(post);

const { title, date, category, tags, cover, description } = post.data;
const siteUrl = 'https://blog.dotw.me';
const canonicalUrl = `${siteUrl}/${getSlug(post.id)}/`;

// All posts for related + prev/next
const allPosts = await getLocalizedPosts('zh-TW');
const currentTags = new Set(tags ?? []);

const relatedPosts = allPosts
  .filter((p) => p.id !== post.id)
  .map((p) => {
    const overlap = (p.data.tags ?? []).filter((t) => currentTags.has(t)).length;
    return { post: p, overlap };
  })
  .filter((p) => p.overlap > 0)
  .sort((a, b) => b.overlap - a.overlap || b.post.data.date.getTime() - a.post.data.date.getTime())
  .slice(0, 3)
  .map((p) => p.post);

// Prev / Next navigation
const sortedAll = [...allPosts].sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const currentIdx = sortedAll.findIndex((p) => p.id === post.id);
const prevPost = currentIdx > 0 ? sortedAll[currentIdx - 1] : null;
const nextPost = currentIdx < sortedAll.length - 1 ? sortedAll[currentIdx + 1] : null;

// Filter headings for TOC (h2 and h3 only)
const tocHeadings = headings.filter((h) => h.depth === 2 || h.depth === 3);
const hasToc = tocHeadings.length >= 3;

// Strip Markdown from description for meta/JSON-LD output
const plainDescription = stripMarkdown(description);

// JSON-LD: Article schema
const jsonLdData = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description: plainDescription,
  url: canonicalUrl,
  datePublished: date.toISOString(),
  dateModified: date.toISOString(),
  author: {
    '@type': 'Person',
    name: 'Logan',
    url: siteUrl,
  },
  publisher: {
    '@type': 'Person',
    name: 'Logan',
    url: siteUrl,
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': canonicalUrl,
  },
  image: {
    '@type': 'ImageObject',
    url: cover ? (cover.startsWith('http') ? cover : `${siteUrl}${cover}`) : `${siteUrl}/og-default.png`,
  },
  ...(tags && tags.length > 0 ? { keywords: tags.join(', ') } : {}),
  ...(category ? { articleSection: category } : {}),
  inLanguage: 'zh-TW',
};
const jsonLd = JSON.stringify(jsonLdData);

// JSON-LD: BreadcrumbList schema
const breadcrumbItems: Array<{ '@type': string; position: number; name: string; item: string }> = [
  { '@type': 'ListItem', position: 1, name: t('common.home'), item: `${siteUrl}/` },
];
if (category) {
  breadcrumbItems.push({
    '@type': 'ListItem',
    position: 2,
    name: category,
    item: `${siteUrl}/categories/${getCategorySlug(category)}/`,
  });
}
breadcrumbItems.push({
  '@type': 'ListItem',
  position: breadcrumbItems.length + 1,
  name: title,
  item: canonicalUrl,
});
const breadcrumbLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: breadcrumbItems,
});
---

<BaseLayout
  title={title}
  description={plainDescription}
  cover={cover ? (cover.startsWith('http') ? cover : `${siteUrl}${cover}`) : undefined}
  canonicalUrl={canonicalUrl}
  ogType="article"
  publishedTime={date}
  tags={tags}
  jsonLd={jsonLd}
  jsonLd2={breadcrumbLd}
>
  <article data-pagefind-body class={hasToc ? 'lg:grid lg:grid-cols-[1fr_240px] lg:gap-10 lg:items-start' : ''}>
    <!-- Main content -->
    <div class="slide-enter-content">
      <!-- Cover image -->
      {
        cover && (
          <div class="mb-4 sm:mb-8 -mx-4 -mt-4 sm:mx-0 sm:mt-0 rounded-none sm:rounded-xl overflow-hidden aspect-[3/1] bg-gray-100 dark:bg-gray-800">
            <img src={cover} alt={title} class="w-full h-full object-cover" />
          </div>
        )
      }

      <header class="mb-4 sm:mb-8">
        <div class="flex flex-wrap items-center gap-2 mb-3 text-sm text-gray-500 dark:text-gray-400">
          {
            category && (
              <CategoryBadge
                category={category}
                href={getLocalePath(`/categories/${getCategorySlug(category)}/`, lang)}
              />
            )
          }
          <time datetime={date.toISOString()} class="text-xs">{formatDate(date)}</time>
          <span class="text-xs">·</span>
          <span class="text-xs">{t('post.readingTime', { min: readingTime(post.body ?? '') })}</span>
        </div>
        <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 dark:text-white leading-snug mb-4">{title}</h1>
        {
          description && (
            <p class="text-gray-600 dark:text-gray-400 text-base leading-relaxed border-l-4 border-[#65cfa0] pl-4 italic">
              {description}
            </p>
          )
        }
      </header>

      {hasToc && <TableOfContents headings={tocHeadings} variant="inline" />}

      <!-- Article content -->
      <div
        class="prose prose-gray dark:prose-invert max-w-none
        prose-headings:font-bold prose-headings:text-gray-900 dark:prose-headings:text-white
        prose-code:before:content-none prose-code:after:content-none
        prose-img:rounded-xl prose-img:mx-auto
        prose-blockquote:not-italic
        text-gray-800 dark:text-gray-200"
      >
        <Content />
      </div>

      <!-- Post footer sections -->
      <div class="mt-6 sm:mt-10 flex flex-col gap-6 sm:gap-10">
        <Divider />
        {
          tags && tags.length > 0 && (
            <>
              <div class="flex flex-wrap gap-2">
                {tags.map((tag) => (
                  <a
                    href={getLocalePath(`/tags/${encodeURIComponent(tag)}/`, lang)}
                    class="text-xs text-gray-600 dark:text-gray-400 bg-gray-100 dark:bg-gray-800 hover:bg-[#f0faf5] dark:hover:bg-[#42b883]/30 hover:text-[#42b883] dark:hover:text-[#65cfa0] px-3 py-1.5 rounded-full transition-colors"
                  >
                    #{tag}
                  </a>
                ))}
              </div>
              <Divider />
            </>
          )
        }

        <AuthorCard />
        <Divider />
        <ShareButtons />
        <Divider />
        <Giscus term={getSlug(post.id)} />
        {relatedPosts.length > 0 && <Divider />}
        <RelatedPosts posts={relatedPosts} />
        {relatedPosts.length > 0 && <Divider />}
        <PostNavigation prevPost={prevPost} nextPost={nextPost} />
      </div>

      <!-- Back link -->
      <div class="mt-6">
        <a
          href={getLocalePath('/', lang)}
          class="inline-flex items-center gap-1.5 text-sm text-gray-600 dark:text-gray-400 hover:text-[#42b883] dark:hover:text-[#65cfa0] transition-colors"
        >
          <Icon name="lucide:arrow-left" class="w-4 h-4" />
          {t('post.backHome')}
        </a>
      </div>
    </div>

    {hasToc && <TableOfContents headings={tocHeadings} variant="sidebar" />}
  </article>

  <!-- Back to top button -->
  <button
    id="back-to-top"
    aria-label={t('post.backToTop')}
    class="fixed bottom-8 right-6 z-50 p-3 rounded-full bg-[#42b883] text-white shadow-lg opacity-0 translate-y-4 transition-[opacity,transform,background-color] duration-300 hover:bg-[#2ea870]"
  >
    <Icon name="lucide:arrow-up" class="w-[18px] h-[18px]" />
  </button>
</BaseLayout>

<script>
  import { initShare } from '@/scripts/article-share';
  import {
    initReadingProgress,
    initBackToTop,
    initLightbox,
    initHeadingAnchors,
    initSmoothScroll,
  } from '@/scripts/article-ui';
  import { initToc, initCodeBlocks } from '@/scripts/article-toc';
  import { initMermaid } from '@/scripts/article-mermaid';

  initShare();
  initCodeBlocks();
  void initMermaid();
  initToc();
  initSmoothScroll();
  initReadingProgress();
  initBackToTop();
  initLightbox();
  initHeadingAnchors();
</script>
