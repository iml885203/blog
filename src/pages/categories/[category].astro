---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import CompactPostCard from '../../components/CompactPostCard.astro';
import { formatDate } from '../../utils/date';

export async function getStaticPaths() {
  const allPosts = await getCollection('posts', ({ data }) => !data.draft);

  // Collect all unique categories
  const categories = new Set<string>();
  for (const post of allPosts) {
    if (post.data.category) categories.add(post.data.category);
  }

  return [...categories].map((category) => {
    const posts = allPosts
      .filter((p) => p.data.category === category)
      .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

    return {
      params: { category },
      props: { category, posts },
    };
  });
}

interface Props {
  category: string;
  posts: Awaited<ReturnType<typeof getCollection>>;
}

const { category, posts } = Astro.props;

function formatDate(date: Date): string {
  return date.toLocaleDateString('zh-TW', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}
---

<BaseLayout
  title={`分類：${category}`}
  description={`${category} 分類下共 ${posts.length} 篇文章。`}
>
  <!-- Breadcrumb -->
  <nav class="flex items-center gap-2 text-sm text-gray-500 dark:text-gray-400 mb-8" aria-label="麵包屑">
    <a href="/" class="hover:text-[#42b883] dark:hover:text-[#65cfa0] transition-colors">首頁</a>
    <span>/</span>
    <a href="/categories/" class="hover:text-[#42b883] dark:hover:text-[#65cfa0] transition-colors">分類</a>
    <span>/</span>
    <span class="text-gray-900 dark:text-white font-medium">{category}</span>
  </nav>

  <!-- Page header -->
  <div class="mb-10 pb-8 border-b border-gray-200 dark:border-gray-800">
    <div class="flex items-center gap-3 mb-1">
      <span class="bg-[#f0faf5] dark:bg-[#42b883]/30 text-[#42b883] dark:text-[#65cfa0] px-3 py-1 rounded-full text-sm font-semibold">
        {category}
      </span>
    </div>
    <p class="text-gray-500 dark:text-gray-400 text-sm mt-2">共 {posts.length} 篇文章</p>
  </div>

  <!-- Post list -->
  <div class="space-y-8">
    {posts.map((post) => (
      <CompactPostCard post={post}  />
    ))}
  </div>

  <!-- Back link -->
  <div class="mt-12 pt-8 border-t border-gray-200 dark:border-gray-800">
    <a
      href="/categories/"
      class="inline-flex items-center gap-2 text-sm text-gray-500 dark:text-gray-400 hover:text-[#42b883] dark:hover:text-[#65cfa0] transition-colors"
    >
      ← 所有分類
    </a>
  </div>
</BaseLayout>
