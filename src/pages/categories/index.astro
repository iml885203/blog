---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const allPosts = await getCollection('posts', ({ data }) => !data.draft);

// Build category map: category → posts[]
const categoryMap = new Map<string, typeof allPosts>();
for (const post of allPosts) {
  const cat = post.data.category;
  if (!cat) continue;
  if (!categoryMap.has(cat)) categoryMap.set(cat, []);
  categoryMap.get(cat)!.push(post);
}

// Sort categories by post count desc
const categories = [...categoryMap.entries()]
  .map(([name, posts]) => ({
    name,
    count: posts.length,
    latest: posts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime())[0],
  }))
  .sort((a, b) => b.count - a.count);

const totalPosts = allPosts.length;
---

<BaseLayout
  title="分類"
  description={`瀏覽所有 ${categories.length} 個分類，共 ${totalPosts} 篇文章。`}
>
  <!-- Page header -->
  <div class="mb-10 pb-8 border-b border-gray-200 dark:border-gray-800">
    <h1 class="text-2xl font-bold text-gray-900 dark:text-white mb-1">分類</h1>
    <p class="text-gray-500 dark:text-gray-400 text-sm">
      共 {categories.length} 個分類 · {totalPosts} 篇文章
    </p>
  </div>

  <!-- Category grid -->
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
    {categories.map(({ name, count, latest }) => (
      <a
        href={`/categories/${encodeURIComponent(name)}/`}
        class="group block p-5 rounded-xl border border-gray-200 dark:border-gray-800 hover:border-[#65cfa0] dark:hover:border-[#42b883] hover:bg-[#f0faf5]/50 dark:hover:bg-[#42b883]/10 transition-all duration-200"
      >
        <div class="flex items-start justify-between gap-2 mb-3">
          <span class="text-base font-semibold text-gray-900 dark:text-white group-hover:text-[#42b883] dark:group-hover:text-[#65cfa0] transition-colors leading-tight">
            {name}
          </span>
          <span class="flex-shrink-0 text-xs font-medium bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400 px-2 py-0.5 rounded-full">
            {count} 篇
          </span>
        </div>
        {latest && (
          <p class="text-xs text-gray-500 dark:text-gray-500 line-clamp-2 leading-relaxed">
            最新：{latest.data.title}
          </p>
        )}
      </a>
    ))}
  </div>
</BaseLayout>
