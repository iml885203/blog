---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Divider from '@/components/Divider.astro';
import { getLangFromUrl, useTranslations, getLocalePath } from '@/i18n/utils';
import { getLocalizedPosts } from '@/i18n/content';
import { getCategorySlug, getCategoryDisplayName } from '@/i18n/categories';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const allPosts = await getLocalizedPosts('zh-TW');

// Build category map: category → posts[]
const categoryMap = new Map<string, typeof allPosts>();
for (const post of allPosts) {
  const cat = post.data.category;
  if (!cat) continue;
  if (!categoryMap.has(cat)) categoryMap.set(cat, []);
  categoryMap.get(cat)!.push(post);
}

// Sort categories by post count desc
const categories = [...categoryMap.entries()]
  .map(([name, posts]) => {
    const sorted = posts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
    return {
      name,
      count: posts.length,
      latest: sorted[0],
      latestDate: sorted[0]?.data.date,
    };
  })
  .sort((a, b) => b.count - a.count);

const totalPosts = allPosts.length;
---

<BaseLayout
  title={t('categories.title')}
  description={t('categories.description', { count: categories.length, posts: totalPosts })}
>
  <div class="flex flex-col gap-6 sm:gap-10 slide-enter-content">
    <div>
      <h1 class="text-2xl font-bold text-gray-900 dark:text-white mb-1">{t('categories.title')}</h1>
      <p class="text-gray-500 dark:text-gray-400 text-sm">
        {t('categories.stats', { count: categories.length, posts: totalPosts })}
      </p>
    </div>

    <Divider />

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      {
        categories.map(({ name, count, latest, latestDate }) => (
          <a
            href={getLocalePath(`/categories/${getCategorySlug(name)}/`, lang)}
            class="group block rounded-xl border border-gray-200 dark:border-gray-800 p-5 hover:border-[#42b883] transition-colors"
          >
            <div class="flex items-start justify-between gap-2 mb-3">
              <span class="text-base font-semibold text-gray-900 dark:text-white group-hover:text-[#42b883] dark:group-hover:text-[#65cfa0] transition-colors leading-tight">
                {getCategoryDisplayName(name, lang)}
              </span>
              <span class="flex-shrink-0 text-xs font-medium bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400 px-2 py-0.5 rounded-full">
                {t('categories.postCount', { count })}
              </span>
            </div>
            {latest && (
              <p class="text-xs text-gray-500 dark:text-gray-500 line-clamp-1 leading-relaxed mb-2">
                {latest.data.title}
              </p>
            )}
            {latestDate && (
              <time class="text-xs text-gray-400 dark:text-gray-600">
                {t('categories.latest', {
                  date: latestDate.toLocaleDateString(lang === 'en' ? 'en-US' : 'zh-TW', {
                    year: 'numeric',
                    month: 'long',
                    day: 'numeric',
                  }),
                })}
              </time>
            )}
          </a>
        ))
      }
    </div>
  </div>
</BaseLayout>
