---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="關於"
  description="嗨，我是 Logan — 資深軟體工程師，熱衷寫程式與智慧家庭。"
  canonicalUrl="https://blog.dotw.me/about/"
>
  <div class="py-8 max-w-2xl">

    <!-- Profile card -->
    <div class="flex items-center gap-5 mb-10">
      <img
        src="https://github.com/iml885203.png"
        alt="Logan"
        width="80"
        height="80"
        class="rounded-full w-20 h-20 object-cover ring-2 ring-gray-200 dark:ring-gray-700 flex-shrink-0"
        loading="eager"
      />
      <div>
        <h1 class="text-2xl font-bold text-gray-900 dark:text-white leading-tight">Logan</h1>
        <p class="text-gray-500 dark:text-gray-400 text-sm mt-1">資深軟體工程師・台灣</p>

        <!-- Social links -->
        <div class="flex items-center gap-4 mt-3">
          <a
            href="https://github.com/iml885203/"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="GitHub"
            class="text-gray-400 hover:text-gray-900 dark:hover:text-white transition-colors duration-200"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
            </svg>
          </a>
          <a
            href="https://www.linkedin.com/in/logan-tw/"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="LinkedIn"
            class="text-gray-400 hover:text-[#0A66C2] transition-colors duration-200"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
          <a
            href="mailto:iml885203@gmail.com"
            aria-label="Email"
            class="text-gray-400 hover:text-[#42b883] dark:hover:text-[#65cfa0] transition-colors duration-200"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
          </a>
        </div>
      </div>
    </div>

    <!-- Content -->
    <div class="prose prose-gray dark:prose-invert max-w-none">
      <h2>關於網站</h2>
      <p>
        這是 <strong>Logan</strong> 的個人網站，你可以在這找到我的開發心得、學習筆記、智慧家庭文章等。
      </p>

      <h2>嗨，我是 Logan</h2>
      <p>
        我是一位資深軟體工程師，我喜歡學習新東西，熱衷於寫程式與玩智慧家庭。
      </p>
      <p>目前居住在台灣。</p>
    </div>
  </div>
</BaseLayout>
