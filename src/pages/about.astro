---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import PostCard from '@/components/PostCard.astro';
import Divider from '@/components/Divider.astro';

const allPosts = await getCollection('posts', ({ data }) => !data.draft);
allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const recentPosts = allPosts.slice(0, 4);
const totalPosts = allPosts.length;
const categories = new Set(allPosts.map((p) => p.data.category).filter(Boolean));
const totalCategories = categories.size;
const earliestDate = allPosts[allPosts.length - 1].data.date;
const yearsWriting = new Date().getFullYear() - earliestDate.getFullYear();

const stats = [
  { value: totalPosts, label: '篇文章' },
  { value: totalCategories, label: '個分類' },
  { value: `${yearsWriting}+`, label: '年寫作' },
];
---

<BaseLayout
  title="關於"
  description="嗨，我是 Logan — 資深軟體工程師，熱衷寫程式與智慧家庭。"
  canonicalUrl="https://blog.dotw.me/about/"
>
  <div class="max-w-2xl mx-auto">
    <!-- Hero -->
    <section class="py-12 sm:py-16 flex flex-col items-center text-center">
      <img
        src="https://github.com/iml885203.png"
        alt="Logan"
        width="128"
        height="128"
        class="rounded-full w-28 h-28 sm:w-32 sm:h-32 object-cover ring-4 ring-[#42b883]/20 dark:ring-[#65cfa0]/20"
        loading="eager"
      />
      <h1 class="text-3xl sm:text-4xl font-bold brand-gradient mt-5">Logan</h1>
      <p class="text-lg text-gray-500 dark:text-gray-400 mt-2">資深軟體工程師・台灣</p>

      <div class="flex items-center gap-3 mt-5">
        <a
          href="https://github.com/iml885203/"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="GitHub"
          class="p-2 rounded-lg text-gray-400 hover:text-gray-900 dark:hover:text-white hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors duration-200"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="22"
            height="22"
            viewBox="0 0 24 24"
            fill="currentColor"
            aria-hidden="true"
          >
            <path
              d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"
            ></path>
          </svg>
        </a>
        <a
          href="https://www.linkedin.com/in/logan-tw/"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="LinkedIn"
          class="p-2 rounded-lg text-gray-400 hover:text-[#0A66C2] hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors duration-200"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="22"
            height="22"
            viewBox="0 0 24 24"
            fill="currentColor"
            aria-hidden="true"
          >
            <path
              d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
            ></path>
          </svg>
        </a>
        <a
          href="mailto:iml885203@gmail.com"
          aria-label="Email"
          class="p-2 rounded-lg text-gray-400 hover:text-[#42b883] dark:hover:text-[#65cfa0] hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors duration-200"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="22"
            height="22"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="1.5"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
            ></path>
          </svg>
        </a>
      </div>
    </section>

    <Divider />

    <!-- 關於我 -->
    <section class="py-8 sm:py-10">
      <h2 class="text-base font-semibold text-gray-700 dark:text-gray-300 mb-4 inline-block">
        <span
          class="pb-1 border-b-2 border-transparent bg-gradient-to-r from-[#42b883] to-[#35495e] bg-[length:100%_2px] bg-no-repeat bg-bottom"
          >關於我</span
        >
      </h2>
      <div class="prose prose-gray dark:prose-invert max-w-none">
        <p>
          這是 <strong>Logan</strong> 的個人網站，你可以在這找到我的開發心得、學習筆記、智慧家庭文章等。
        </p>
        <p>我是一位資深軟體工程師，熱衷於寫程式與玩智慧家庭。目前居住在台灣。</p>
      </div>
    </section>

    <Divider />

    <!-- 部落格數據 -->
    <section class="py-8 sm:py-10">
      <h2 class="text-base font-semibold text-gray-700 dark:text-gray-300 mb-6 inline-block">
        <span
          class="pb-1 border-b-2 border-transparent bg-gradient-to-r from-[#42b883] to-[#35495e] bg-[length:100%_2px] bg-no-repeat bg-bottom"
          >部落格數據</span
        >
      </h2>
      <div class="grid grid-cols-3 gap-3 sm:gap-6">
        {
          stats.map(({ value, label }) => (
            <div class="card-hover-glow rounded-xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900 p-4 sm:p-6 text-center">
              <div class="text-2xl sm:text-3xl font-bold text-[#42b883] dark:text-[#65cfa0]">{value}</div>
              <div class="text-xs sm:text-sm text-gray-500 dark:text-gray-400 mt-1">{label}</div>
            </div>
          ))
        }
      </div>
    </section>

    <Divider />

    <!-- 最新文章 -->
    <section class="py-8 sm:py-10">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-base font-semibold text-gray-700 dark:text-gray-300 inline-block">
          <span
            class="pb-1 border-b-2 border-transparent bg-gradient-to-r from-[#42b883] to-[#35495e] bg-[length:100%_2px] bg-no-repeat bg-bottom"
            >最新文章</span
          >
        </h2>
        <a href="/archives/" class="text-sm text-[#42b883] dark:text-[#65cfa0] hover:underline">查看全部 &rarr;</a>
      </div>
      <div class="grid gap-6 sm:grid-cols-2">
        {recentPosts.map((post) => <PostCard post={post} />)}
      </div>
    </section>
  </div>
</BaseLayout>
