---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="搜尋" description="搜尋文章">
  <div class="max-w-2xl mx-auto">
    <h1 class="text-2xl font-bold mb-6 text-gray-900 dark:text-white">搜尋</h1>

    <!-- Search input -->
    <div class="relative mb-8">
      <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24"
          stroke="currentColor" stroke-width="2" class="text-gray-400">
          <circle cx="11" cy="11" r="8" />
          <path stroke-linecap="round" d="m21 21-4.35-4.35" />
        </svg>
      </div>
      <input
        id="search-input"
        type="search"
        placeholder="搜尋文章..."
        autofocus
        class="w-full pl-10 pr-4 py-3 rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-900 text-gray-900 dark:text-white placeholder-gray-400 dark:placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-colors"
      />
    </div>

    <!-- Results -->
    <div id="search-results" class="space-y-4">
      <p id="search-hint" class="text-gray-500 dark:text-gray-400 text-sm">輸入關鍵字開始搜尋...</p>
    </div>
  </div>
</BaseLayout>

<style>
  @reference "tailwindcss";
  .result-card {
    @apply block p-4 rounded-lg border border-gray-200 hover:border-blue-400 transition-colors bg-white;
  }
  :global(.dark) .result-card {
    @apply border-gray-700 hover:border-blue-500 bg-gray-900;
  }
  mark {
    @apply bg-yellow-100 text-gray-900 rounded px-0.5;
  }
  :global(.dark) mark {
    @apply bg-yellow-900/50 text-yellow-200;
  }
</style>

<script>
  async function initSearch() {
    // @ts-ignore - pagefind is loaded as a static asset after build
    const pagefind = await import('/pagefind/pagefind.js');
    await pagefind.init();

    const input = document.getElementById('search-input') as HTMLInputElement;
    const resultsEl = document.getElementById('search-results')!;
    const hintEl = document.getElementById('search-hint')!;

    // Check for query param
    const params = new URLSearchParams(window.location.search);
    const q = params.get('q');
    if (q) {
      input.value = q;
      doSearch(q);
    }

    input.addEventListener('input', () => {
      const query = input.value.trim();
      // Update URL without reload
      const url = new URL(window.location.href);
      if (query) {
        url.searchParams.set('q', query);
      } else {
        url.searchParams.delete('q');
      }
      window.history.replaceState(null, '', url.toString());
      doSearch(query);
    });

    async function doSearch(query: string) {
      if (!query) {
        resultsEl.innerHTML = '';
        resultsEl.appendChild(hintEl);
        hintEl.textContent = '輸入關鍵字開始搜尋...';
        return;
      }

      const results = await pagefind.search(query);

      if (results.results.length === 0) {
        resultsEl.innerHTML = `<p class="text-gray-500 dark:text-gray-400 text-sm">找不到「${query}」的相關文章</p>`;
        return;
      }

      // Load first 10 results
      const loaded = await Promise.all(results.results.slice(0, 10).map((r: any) => r.data()));

      resultsEl.innerHTML = `
        <p class="text-sm text-gray-500 dark:text-gray-400 mb-4">找到 ${results.results.length} 筆結果</p>
        ${loaded.map((r: any) => `
          <a href="${r.url}" class="result-card group">
            <h2 class="text-base font-semibold text-gray-900 dark:text-white group-hover:text-blue-600 dark:group-hover:text-blue-400 mb-1 line-clamp-2">
              ${r.meta?.title || '（無標題）'}
            </h2>
            ${r.excerpt ? `<p class="text-sm text-gray-600 dark:text-gray-400 line-clamp-3">${r.excerpt}</p>` : ''}
          </a>
        `).join('')}
      `;
    }
  }

  // Only init in browser (not SSR)
  initSearch().catch(() => {
    const resultsEl = document.getElementById('search-results');
    if (resultsEl) {
      resultsEl.innerHTML = '<p class="text-red-500 text-sm">搜尋功能載入失敗，請確認網站已正確建置。</p>';
    }
  });
</script>
