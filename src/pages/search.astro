---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PagefindSearch from 'astro-pagefind/components/Search';
---

<BaseLayout title="搜尋" description="搜尋文章">
  <div class="max-w-2xl mx-auto">
    <h1 class="text-2xl font-bold mb-6 text-gray-900 dark:text-white">搜尋</h1>
    <PagefindSearch id="search" className="pagefind-ui" uiOptions={{ showImages: false, showEmptyFilters: false }} />
  </div>
</BaseLayout>

<script>
  function initSearch() {
    const q = new URLSearchParams(window.location.search).get('q');
    const input = document.querySelector<HTMLInputElement>('.pagefind-ui__search-input');
    if (!input) return;

    if (q && !input.value) {
      input.value = q;
      input.dispatchEvent(new Event('input', { bubbles: true }));
    }

    let debounceTimer: ReturnType<typeof setTimeout>;
    input.addEventListener('input', () => {
      clearTimeout(debounceTimer);
      debounceTimer = setTimeout(() => {
        const url = new URL(window.location.href);
        if (input.value) {
          url.searchParams.set('q', input.value);
        } else {
          url.searchParams.delete('q');
        }
        history.replaceState(null, '', url.toString());
      }, 300);
    });
  }

  // Pagefind UI renders async, wait for input to appear
  const container = document.querySelector('.pagefind-ui') ?? document.body;
  const observer = new MutationObserver(() => {
    if (document.querySelector('.pagefind-ui__search-input')) {
      observer.disconnect();
      clearTimeout(observerTimeout);
      initSearch();
    }
  });
  const observerTimeout = setTimeout(() => observer.disconnect(), 5000);
  observer.observe(container, { childList: true, subtree: true });
</script>

<style is:global>
  .pagefind-ui {
    --pagefind-ui-primary: #42b883;
    --pagefind-ui-text: #1f2937;
    --pagefind-ui-background: #ffffff;
    --pagefind-ui-border: #e5e7eb;
    --pagefind-ui-tag: #f3f4f6;
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 0.75rem;
    --pagefind-ui-font: 'Noto Sans TC', system-ui, sans-serif;
  }

  .dark .pagefind-ui {
    --pagefind-ui-text: #e5e7eb;
    --pagefind-ui-background: #111827;
    --pagefind-ui-border: #374151;
    --pagefind-ui-tag: #1f2937;
  }

  .pagefind-ui .pagefind-ui__search-input {
    font-size: 1rem;
    padding: 0.75rem 1rem 0.75rem 2.5rem;
  }

  .pagefind-ui .pagefind-ui__result-link {
    color: #1f2937;
  }

  .dark .pagefind-ui .pagefind-ui__result-link {
    color: #e5e7eb;
  }

  .pagefind-ui .pagefind-ui__result-link:hover {
    color: #42b883;
  }

  .pagefind-ui mark {
    background: #fef08a;
    color: #1f2937;
    border-radius: 2px;
    padding: 0 2px;
  }

  .dark .pagefind-ui mark {
    background: rgba(120, 113, 43, 0.5);
    color: #fde68a;
  }
</style>
