---
// Mermaid Playground — dev only, not in sitemap
const examples = [
  {
    label: 'Flowchart LR（6 nodes）',
    code: `graph LR
  A[Start] --> B[Step 1]
  B --> C[Step 2]
  C --> D[Step 3]
  D --> E[Step 4]
  E --> F[End]`,
  },
  {
    label: 'Flowchart TD（6 nodes）',
    code: `graph TD
  A[Start] --> B[Step 1]
  B --> C[Step 2]
  C --> D[Step 3]
  D --> E[Step 4]
  E --> F[End]`,
  },
  {
    label: 'Flowchart LR（real blog example）',
    code: `graph LR
  A[brainstorming] --> B[設計確認]
  B --> C[using-git-worktrees]
  C --> D[writing-plans]
  D --> E[逐 task: implementer]
  E --> F[spec compliance review]
  F --> G[code quality review]
  G --> H[finishing-a-development-branch]
  H --> I[merge/PR/保留/丟棄]`,
  },
  {
    label: 'Flowchart TD（real blog example）',
    code: `graph TD
  A[brainstorming] --> B[設計確認]
  B --> C[using-git-worktrees]
  C --> D[writing-plans]
  D --> E[逐 task: implementer]
  E --> F[spec compliance review]
  F --> G[code quality review]
  G --> H[finishing-a-development-branch]
  H --> I[merge/PR/保留/丟棄]`,
  },
  {
    label: 'Flowchart with dashed edge',
    code: `graph LR
  A["/office-hours"] --> B["/plan-ceo-review 或 /autoplan"]
  B --> C["/plan-eng-review"]
  C --> D[實作]
  D --> E["/review"]
  E --> F["/qa ± /cso"]
  F --> G["/ship"]
  G --> H["/retro"]
  D -.高風險操作.-> X["/careful 或 /freeze"]`,
  },
];
---

<!DOCTYPE html>
<html lang="zh-TW">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Mermaid Playground</title>
    <style>
      * { box-sizing: border-box; }
      body { font-family: system-ui, sans-serif; margin: 0; padding: 1.5rem; background: #f8fafc; color: #1e293b; }
      h1 { font-size: 1.5rem; margin-bottom: 0.5rem; }
      .meta { color: #64748b; font-size: 0.875rem; margin-bottom: 2rem; }
      .grid { display: grid; gap: 2rem; }
      .card { background: white; border: 1px solid #e2e8f0; border-radius: 0.75rem; padding: 1.25rem; }
      .card h2 { font-size: 0.875rem; font-weight: 600; margin: 0 0 0.75rem; color: #475569; text-transform: uppercase; letter-spacing: 0.05em; }
      .diagram-wrap { border: 1px dashed #cbd5e1; border-radius: 0.5rem; padding: 0.5rem; overflow-x: auto; }
      .mermaid { display: flex; justify-content: center; }
      code { display: block; background: #f1f5f9; border-radius: 0.5rem; padding: 0.75rem; font-size: 0.8rem; white-space: pre; overflow-x: auto; margin-top: 0.75rem; color: #334155; font-family: monospace; }
      .size-info { font-size: 0.75rem; color: #94a3b8; margin-top: 0.5rem; text-align: right; }
    </style>
  </head>
  <body>
    <h1>🧪 Mermaid Playground</h1>
    <p class="meta">用來測試 Mermaid 渲染效果 — 對比 LR vs TD，簡單 vs 複雜</p>

    <div class="grid">
      {examples.map((ex, i) => (
        <div class="card">
          <h2>{ex.label}</h2>
          <div class="diagram-wrap">
            <div class="mermaid" data-idx={i}>
              {ex.code}
            </div>
          </div>
          <p class="size-info" id={`size-${i}`}>（計算中…）</p>
          <code>{ex.code}</code>
        </div>
      ))}
    </div>

    <script>
      import mermaid from 'mermaid';

      const isDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      mermaid.initialize({
        startOnLoad: false,
        securityLevel: 'strict',
        theme: isDark ? 'dark' : 'neutral',
        flowchart: { useMaxWidth: true, htmlLabels: true, curve: 'basis' },
      });

      await mermaid.run({ querySelector: '.mermaid' });

      // Show rendered SVG size info
      document.querySelectorAll('.mermaid').forEach((el, i) => {
        const svg = el.querySelector('svg');
        if (!svg) return;
        const r = svg.getBoundingClientRect();
        const vb = svg.getAttribute('viewBox') || '';
        const info = document.getElementById(`size-${i}`);
        if (info) info.textContent = `rendered: ${Math.round(r.width)}×${Math.round(r.height)}px | viewBox: ${vb}`;
      });
    </script>
  </body>
</html>
