---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Divider from '@/components/Divider.astro';
import { getLangFromUrl, useTranslations, getLocalePath } from '@/i18n/utils';
import { getLocalizedPosts } from '@/i18n/content';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const allPosts = await getLocalizedPosts('en');

// Build tag map: tag → posts[]
const tagMap = new Map<string, typeof allPosts>();
for (const post of allPosts) {
  const tags = post.data.tags ?? [];
  for (const tag of tags) {
    if (!tagMap.has(tag)) tagMap.set(tag, []);
    tagMap.get(tag)!.push(post);
  }
}

// Sort tags by post count desc
const tags = [...tagMap.entries()]
  .map(([name, posts]) => ({
    name,
    count: posts.length,
  }))
  .sort((a, b) => b.count - a.count);

const totalPosts = allPosts.length;
---

<BaseLayout title={t('tags.title')} description={t('tags.description', { count: tags.length, posts: totalPosts })}>
  <div class="flex flex-col gap-6 sm:gap-10 slide-enter-content">
    <div>
      <h1 class="text-2xl font-bold text-gray-900 dark:text-white mb-1">{t('tags.title')}</h1>
      <p class="text-gray-500 dark:text-gray-400 text-sm">
        {t('tags.stats', { count: tags.length, posts: totalPosts })}
      </p>
    </div>

    <Divider />

    <div class="flex flex-wrap gap-3">
      {
        tags.map(({ name, count }) => {
          // Discrete size classes by post count
          const sizeClass =
            count >= 7
              ? 'text-xl font-semibold'
              : count >= 4
                ? 'text-lg font-medium'
                : count >= 2
                  ? 'text-base font-medium'
                  : 'text-sm font-normal';

          return (
            <a
              href={getLocalePath(`/tags/${encodeURIComponent(name)}/`, lang)}
              class={`group inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full border border-gray-200 dark:border-gray-700 hover:border-[#65cfa0] dark:hover:border-[#42b883] hover:bg-[#f0faf5]/50 dark:hover:bg-[#42b883]/10 transition-colors duration-200 ${sizeClass}`}
            >
              <span class="text-gray-700 dark:text-gray-300 group-hover:text-[#42b883] dark:group-hover:text-[#65cfa0] transition-colors">
                #{name}
              </span>
              <span class="text-xs text-gray-400 dark:text-gray-500 group-hover:text-[#42b883] dark:group-hover:text-[#42b883] transition-colors">
                {count}
              </span>
            </a>
          );
        })
      }
    </div>
  </div>
</BaseLayout>
