---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getLangFromUrl, useTranslations, getLocalePath } from '@/i18n/utils';
import { getLocalizedPosts, getSlug } from '@/i18n/content';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const allPosts = await getLocalizedPosts('en');
const randomPost = allPosts[Math.floor(Math.random() * allPosts.length)];
---

<BaseLayout title={t('404.title')} description={t('404.description')}>
  <div class="flex flex-col items-center justify-center py-16 sm:py-24">
    <!-- Terminal -->
    <div class="w-full max-w-lg rounded-xl overflow-hidden border border-gray-200 dark:border-gray-800 shadow-lg">
      <!-- Title bar -->
      <div
        class="flex items-center gap-2 px-4 py-3 bg-gray-100 dark:bg-gray-800 border-b border-gray-200 dark:border-gray-700"
      >
        <span class="w-3 h-3 rounded-full bg-red-400"></span>
        <span class="w-3 h-3 rounded-full bg-yellow-400"></span>
        <span class="w-3 h-3 rounded-full bg-green-400"></span>
        <span class="flex-1 text-center text-xs text-gray-400 dark:text-gray-500 font-mono">terminal</span>
      </div>
      <!-- Terminal body -->
      <div class="bg-gray-900 dark:bg-[#0a0a0a] p-5 sm:p-6 font-mono text-sm leading-relaxed">
        <p class="text-gray-400">
          <span class="text-[#42b883]">logan@blog</span><span class="text-gray-500">:</span><span class="text-blue-400"
            >~</span
          ><span class="text-gray-500">$</span>
          <span id="typed-cmd" class="text-gray-200 ml-1"></span><span
            id="cursor"
            class="inline-block w-2 h-4 bg-gray-200 align-middle ml-px animate-blink"></span>
        </p>
        <p id="error-line" class="text-red-400 mt-2 opacity-0 transition-opacity duration-300">
          zsh: command not found: 404
        </p>
        <p id="suggest-line" class="text-gray-400 mt-3 opacity-0 transition-opacity duration-300">
          <span class="text-yellow-400">hint:</span>
          {t('404.hint')}
          <a href={getLocalePath(`/${getSlug(randomPost.id)}/`, lang)} class="text-[#42b883] hover:underline"
            >{randomPost.data.title}</a
          >
        </p>
      </div>
    </div>

    <!-- Actions -->
    <div class="mt-8 flex gap-4">
      <a
        href={getLocalePath('/', lang)}
        class="bg-[#42b883] text-white rounded-lg px-5 py-2.5 text-sm font-medium hover:bg-[#2ea870] transition-colors"
      >
        cd ~
      </a>
      <a
        href={getLocalePath('/search', lang)}
        class="border border-gray-300 dark:border-gray-600 text-gray-700 dark:text-gray-300 rounded-lg px-5 py-2.5 text-sm font-medium hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors font-mono"
      >
        grep ...
      </a>
    </div>
  </div>
</BaseLayout>

<style>
  @keyframes blink {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0;
    }
  }
  .animate-blink {
    animation: blink 1s step-end infinite;
  }
</style>

<script>
  const cmd = 'cat ./this-page';
  const typed = document.getElementById('typed-cmd');
  const cursor = document.getElementById('cursor');
  const errorLine = document.getElementById('error-line');
  const suggestLine = document.getElementById('suggest-line');

  if (typed && cursor && errorLine && suggestLine) {
    let i = 0;
    const interval = setInterval(() => {
      typed.textContent += cmd[i];
      i++;
      if (i >= cmd.length) {
        clearInterval(interval);
        setTimeout(() => {
          cursor.classList.add('hidden');
          errorLine.classList.remove('opacity-0');
          errorLine.classList.add('opacity-100');
          setTimeout(() => {
            suggestLine.classList.remove('opacity-0');
            suggestLine.classList.add('opacity-100');
          }, 400);
        }, 300);
      }
    }, 60);
  }
</script>
