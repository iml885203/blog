---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PostCard from '@/components/PostCard.astro';
import Pagination from '@/components/Pagination.astro';
import { getLangFromUrl, useTranslations } from '@/i18n/utils';
import { getLocalizedPosts } from '@/i18n/content';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const POSTS_PER_PAGE = 10;
const allPosts = await getLocalizedPosts(lang);
allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const totalPages = Math.ceil(allPosts.length / POSTS_PER_PAGE);
const posts = allPosts.slice(0, POSTS_PER_PAGE);
---

<BaseLayout title={t('home.title')} description={t('site.description')}>
  <div class="grid gap-6 sm:grid-cols-2 slide-enter-content">
    {posts.map((post) => <PostCard post={post} />)}
  </div>

  <Pagination currentPage={1} totalPages={totalPages} totalPosts={allPosts.length} baseUrl="/" />
</BaseLayout>
