---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Divider from '@/components/Divider.astro';
import CompactPostCard from '@/components/CompactPostCard.astro';
import CategoryBadge from '@/components/CategoryBadge.astro';
import { formatDate } from '@/utils/date';
import { getLangFromUrl, useTranslations, getLocalePath } from '@/i18n/utils';
import { getLocalizedPosts } from '@/i18n/content';
import { getCategorySlug, getCategoryDisplayName } from '@/i18n/categories';

export async function getStaticPaths() {
  const allPosts = await getLocalizedPosts('en');

  // Collect all unique categories
  const categories = new Set<string>();
  for (const post of allPosts) {
    if (post.data.category) categories.add(post.data.category);
  }

  return [...categories].map((category) => {
    const posts = allPosts
      .filter((p) => p.data.category === category)
      .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

    return {
      params: { category: getCategorySlug(category) },
      props: { category, posts },
    };
  });
}

interface Props {
  category: string;
  posts: Awaited<ReturnType<typeof getCollection>>;
}

const { category, posts } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<BaseLayout
  title={`${t('categories.title')}：${getCategoryDisplayName(category, lang)}`}
  description={`${getCategoryDisplayName(category, lang)} — ${t('categories.totalPosts', { count: posts.length })}`}
>
  <!-- Breadcrumb -->
  <nav class="flex items-center gap-2 text-sm text-gray-500 dark:text-gray-400 mb-8" aria-label={t('aria.breadcrumb')}>
    <a href={getLocalePath('/', lang)} class="hover:text-[#42b883] dark:hover:text-[#65cfa0] transition-colors"
      >{t('common.home')}</a
    >
    <span>/</span>
    <a
      href={getLocalePath('/categories/', lang)}
      class="hover:text-[#42b883] dark:hover:text-[#65cfa0] transition-colors">{t('categories.title')}</a
    >
    <span>/</span>
    <span class="text-gray-900 dark:text-white font-medium">{getCategoryDisplayName(category, lang)}</span>
  </nav>

  <div class="flex flex-col gap-6 sm:gap-10 slide-enter-content">
    <div>
      <div class="flex items-center gap-3 mb-1">
        <CategoryBadge category={category} size="sm" />
      </div>
      <p class="text-gray-500 dark:text-gray-400 text-sm mt-2">{t('categories.totalPosts', { count: posts.length })}</p>
    </div>

    <Divider />

    <div class="space-y-3 sm:space-y-6">
      {posts.map((post) => <CompactPostCard post={post} />)}
    </div>

    <Divider />

    <a
      href={getLocalePath('/categories/', lang)}
      class="inline-flex items-center gap-2 text-sm text-gray-500 dark:text-gray-400 hover:text-[#42b883] dark:hover:text-[#65cfa0] transition-colors"
    >
      {t('categories.backToAll')}
    </a>
  </div>
</BaseLayout>
