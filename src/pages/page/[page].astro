---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Divider from '@/components/Divider.astro';
import PostCard from '@/components/PostCard.astro';
import Pagination from '@/components/Pagination.astro';
import { getLangFromUrl, getLangFromFilePath, useTranslations } from '@/i18n/utils';
import { getLocalizedPosts } from '@/i18n/content';

export async function getStaticPaths() {
  const POSTS_PER_PAGE = 10;
  const allPosts = await getLocalizedPosts(getLangFromFilePath(import.meta.url));
  const totalPages = Math.ceil(allPosts.length / POSTS_PER_PAGE);

  return Array.from({ length: totalPages - 1 }, (_, i) => ({
    params: { page: String(i + 2) },
    props: { currentPage: i + 2, totalPages, allPosts },
  }));
}

const POSTS_PER_PAGE = 10;
const { currentPage, totalPages, allPosts } = Astro.props;
allPosts.sort((a: any, b: any) => b.data.date.getTime() - a.data.date.getTime());
const posts = allPosts.slice((currentPage - 1) * POSTS_PER_PAGE, currentPage * POSTS_PER_PAGE);
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<BaseLayout
  title={`${t('pagination.page', { page: currentPage })} | ${t('site.title')}`}
  description={t('site.description')}
>
  <div class="flex flex-col gap-6 sm:gap-10 slide-enter-content">
    <div>
      <h1 class="text-2xl font-bold text-gray-900 dark:text-white mb-1">{t('site.title')}</h1>
      <p class="text-gray-500 dark:text-gray-400 text-sm">{t('site.subtitle')}</p>
    </div>

    <Divider />

    <div class="grid gap-6 sm:grid-cols-2">
      {posts.map((post: any) => <PostCard post={post} />)}
    </div>

    <Pagination currentPage={currentPage} totalPages={totalPages} totalPosts={allPosts.length} baseUrl="/" />
  </div>
</BaseLayout>
