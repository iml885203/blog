---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { stripMarkdown } from '../../utils/markdown';

export async function getStaticPaths() {
  const POSTS_PER_PAGE = 10;
  const allPosts = await getCollection('posts', ({ data }) => !data.draft);
  const totalPages = Math.ceil(allPosts.length / POSTS_PER_PAGE);

  return Array.from({ length: totalPages - 1 }, (_, i) => ({
    params: { page: String(i + 2) },
    props: { currentPage: i + 2, totalPages, allPosts },
  }));
}

const POSTS_PER_PAGE = 10;
const { currentPage, totalPages, allPosts } = Astro.props;

allPosts.sort((a: any, b: any) => b.data.date.getTime() - a.data.date.getTime());
const posts = allPosts.slice((currentPage - 1) * POSTS_PER_PAGE, currentPage * POSTS_PER_PAGE);

function formatDate(date: Date): string {
  return date.toLocaleDateString('zh-TW', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}
---

<BaseLayout
  title={`第 ${currentPage} 頁 | Logan 的隨手筆記`}
  description="Logan 的技術部落格，分享軟體工程、智慧家庭與生活觀察。"
>
  <!-- Header -->
  <div class="mb-10 pb-8 border-b border-gray-200 dark:border-gray-800">
    <h1 class="text-2xl font-bold text-gray-900 dark:text-white mb-1">Logan 的隨手筆記</h1>
    <p class="text-gray-500 dark:text-gray-400 text-sm">軟體工程 · 智慧家庭 · 生活觀察</p>
  </div>

  <!-- Post list -->
  <div class="space-y-10">
    {posts.map((post: any) => (
      <article class="group">
        <a href={`/${post.id}/`} class="block">
          {post.data.cover && (
            <div class="mb-4 rounded-xl overflow-hidden aspect-[2/1] bg-gray-100 dark:bg-gray-800">
              <img
                src={post.data.cover}
                alt={post.data.title}
                loading="lazy"
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
              />
            </div>
          )}

          <div class="flex items-center gap-2 mb-2 text-xs text-gray-500 dark:text-gray-400">
            {post.data.category && (
              <span class="bg-blue-50 dark:bg-blue-900/30 text-blue-600 dark:text-blue-400 px-2 py-0.5 rounded-full font-medium">
                {post.data.category}
              </span>
            )}
            <time datetime={post.data.date.toISOString()}>
              {formatDate(post.data.date)}
            </time>
          </div>

          <h2 class="text-xl font-bold text-gray-900 dark:text-white group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors leading-snug mb-2">
            {post.data.title}
          </h2>

          {post.data.description && (
            <p class="text-gray-600 dark:text-gray-400 text-sm leading-relaxed line-clamp-3">
              {stripMarkdown(post.data.description)}
            </p>
          )}
        </a>

        {post.data.tags && post.data.tags.length > 0 && (
          <div class="flex flex-wrap gap-1.5 mt-3">
            {post.data.tags.slice(0, 4).map((tag: string) => (
              <a
                href={`/tags/${encodeURIComponent(tag)}/`}
                class="text-xs text-gray-500 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors"
              >
                #{tag}
              </a>
            ))}
          </div>
        )}
      </article>
    ))}
  </div>

  <!-- Pagination -->
  <nav class="mt-12 flex flex-col items-center gap-4" aria-label="分頁">
    <div class="flex items-center gap-2 flex-wrap justify-center">
      {currentPage > 1 && (
        <a
          href={currentPage === 2 ? '/' : `/page/${currentPage - 1}/`}
          class="border border-gray-300 dark:border-gray-600 rounded-full px-4 py-2 text-sm text-gray-600 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors"
        >
          ←
        </a>
      )}
      {Array.from({ length: totalPages }, (_, i) => i + 1).map((p: number) => (
        <a
          href={p === 1 ? '/' : `/page/${p}/`}
          class={p === currentPage
            ? 'bg-blue-600 text-white rounded-full px-4 py-2 text-sm font-medium'
            : 'border border-gray-300 dark:border-gray-600 rounded-full px-4 py-2 text-sm text-gray-600 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors'}
        >
          {p}
        </a>
      ))}
      {currentPage < totalPages && (
        <a
          href={`/page/${currentPage + 1}/`}
          class="border border-gray-300 dark:border-gray-600 rounded-full px-4 py-2 text-sm text-gray-600 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors"
        >
          →
        </a>
      )}
    </div>
    <span class="text-sm text-gray-500 dark:text-gray-400">
      第 {currentPage} / {totalPages} 頁，共 {allPosts.length} 篇
    </span>
  </nav>
</BaseLayout>
