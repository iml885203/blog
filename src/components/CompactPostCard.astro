---
import { stripMarkdown } from '@/utils/markdown';
import { formatDate } from '@/utils/date';
import { getLangFromUrl, getLocalePath } from '@/i18n/utils';
const lang = getLangFromUrl(Astro.url);

interface Props {
  post: {
    id: string;
    data: {
      title: string;
      date: Date;
      description?: string;
      cover?: string;
      category?: string;
      tags?: string[];
    };
  };
  activeTag?: string;
}

const { post, activeTag } = Astro.props;
const { title, date, description, cover, category, tags } = post.data;
---

<article
  class="group rounded-xl border border-gray-200 dark:border-gray-800 overflow-hidden hover:border-[#42b883] dark:hover:border-[#42b883] transition-colors flex flex-row"
>
  <a href={getLocalePath(`/${post.id}/`, lang)} class="flex-shrink-0">
    <div class="w-24 sm:w-32 aspect-square bg-gray-100 dark:bg-gray-800 overflow-hidden">
      {
        cover ? (
          <img
            src={cover}
            alt={title}
            loading="lazy"
            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
          />
        ) : (
          <div class="w-full h-full bg-gradient-to-br from-[#f0faf5] to-[#e0f5ec] dark:from-[#42b883]/20 dark:to-[#35495e]/30 flex items-center justify-center">
            <span class="text-2xl font-bold text-[#42b883]/40 dark:text-[#65cfa0]/30 select-none">
              {title.charAt(0)}
            </span>
          </div>
        )
      }
    </div>
  </a>

  <div class="flex-1 min-w-0 p-3 sm:p-4 flex flex-col justify-center">
    <div class="flex items-center gap-2 mb-1 text-xs text-gray-500 dark:text-gray-400">
      <time datetime={date.toISOString()}>{formatDate(date)}</time>
      {
        category && (
          <>
            <span>·</span>
            <a
              href={getLocalePath(`/categories/${encodeURIComponent(category)}/`, lang)}
              class="hover:text-[#42b883] dark:hover:text-[#65cfa0] transition-colors"
            >
              {category}
            </a>
          </>
        )
      }
    </div>

    <h2
      class="text-base sm:text-lg font-semibold text-gray-900 dark:text-white group-hover:text-[#42b883] dark:group-hover:text-[#65cfa0] transition-colors leading-snug line-clamp-2"
    >
      <a href={getLocalePath(`/${post.id}/`, lang)}>{title}</a>
    </h2>

    {
      description && (
        <p class="hidden sm:block text-gray-600 dark:text-gray-400 text-sm leading-relaxed line-clamp-1 mt-1">
          {stripMarkdown(description)}
        </p>
      )
    }

    {
      tags && tags.length > 0 && (
        <div class="hidden sm:flex flex-wrap gap-1.5 mt-1.5">
          {tags.slice(0, 4).map((t) => (
            <a
              href={getLocalePath(`/tags/${encodeURIComponent(t)}/`, lang)}
              class={`text-xs transition-colors ${
                t === activeTag
                  ? 'text-[#42b883] dark:text-[#65cfa0] font-medium'
                  : 'text-gray-500 dark:text-gray-400 hover:text-[#42b883] dark:hover:text-[#65cfa0]'
              }`}
            >
              #{t}
            </a>
          ))}
        </div>
      )
    }
  </div>
</article>
