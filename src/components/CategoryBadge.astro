---
interface Props {
  category: string;
  href?: string;
  size?: 'xs' | 'sm';
}

const { category, href, size = 'xs' } = Astro.props;
const sizeClass = size === 'sm' ? 'text-sm px-3 py-1' : 'text-xs px-2.5 py-0.5';
const baseClass = `bg-[#f0faf5] dark:bg-[#42b883]/30 text-[#42b883] dark:text-[#65cfa0] rounded-full font-medium ${sizeClass}`;
const hoverClass = 'hover:bg-[#e0f5ec] dark:hover:bg-[#42b883]/20 transition-colors';
---

{href ? (
  <a href={href} class={`${baseClass} ${hoverClass}`}>{category}</a>
) : (
  <span class={baseClass}>{category}</span>
)}
