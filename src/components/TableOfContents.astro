---
interface Props {
  headings: { depth: number; slug: string; text: string }[];
  variant: 'inline' | 'sidebar';
}

import { Icon } from 'astro-icon/components';
import { getLangFromUrl, useTranslations } from '@/i18n/utils';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const { headings, variant } = Astro.props;
---

{
  variant === 'inline' ? (
    <nav
      id="toc-inline"
      class="lg:hidden mb-8 p-4 bg-gray-50 dark:bg-gray-800/50 rounded-xl border border-gray-200 dark:border-gray-700"
      aria-label={t('aria.toc')}
    >
      <div class="flex items-center justify-between mb-3 cursor-pointer" id="toc-inline-toggle">
        <span class="text-sm font-semibold text-gray-700 dark:text-gray-300">{t('post.toc')}</span>
        <Icon
          id="toc-inline-icon"
          name="lucide:chevron-down"
          size={16}
          aria-hidden="true"
          class="transition-transform duration-200"
        />
      </div>
      <ol id="toc-inline-list" class="space-y-1 text-sm">
        {headings.map((h) => (
          <li class={h.depth === 3 ? 'ml-4' : ''}>
            <a
              href={`#${h.slug}`}
              class="text-gray-600 dark:text-gray-400 hover:text-[#42b883] dark:hover:text-[#65cfa0] transition-colors block py-0.5 truncate"
            >
              {h.text}
            </a>
          </li>
        ))}
      </ol>
    </nav>
  ) : (
    <aside class="hidden lg:block">
      <nav
        id="toc-sidebar"
        class="sticky top-20 max-h-[calc(100vh-6rem)] overflow-y-auto bg-white dark:bg-gray-900 rounded-xl border border-gray-100 dark:border-gray-800 p-4"
        aria-label={t('aria.toc')}
      >
        <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-3">{t('post.toc')}</p>
        <ol class="space-y-1 text-sm" id="toc-list">
          {headings.map((h) => (
            <li class={h.depth === 3 ? 'ml-3' : ''}>
              <a
                href={`#${h.slug}`}
                data-toc-slug={h.slug}
                class="toc-link block py-1 text-gray-600 dark:text-gray-400 hover:text-[#42b883] dark:hover:text-[#65cfa0] transition-colors leading-snug border-l-2 border-transparent pl-2"
              >
                {h.text}
              </a>
            </li>
          ))}
        </ol>
      </nav>
    </aside>
  )
}
