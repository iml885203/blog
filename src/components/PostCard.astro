---
import { readingTime, stripMarkdown } from '@/utils/markdown';
import { formatDate } from '@/utils/date';
import CategoryBadge from './CategoryBadge.astro';

interface Props {
  post: {
    id: string;
    data: {
      title: string;
      date: Date;
      description?: string;
      cover?: string;
      category?: string;
      tags?: string[];
    };
    body?: string;
  };
}

const { post } = Astro.props;
const { title, date, description, cover, category, tags } = post.data;
---

<article
  class="group card-hover-glow bg-white dark:bg-gray-900 rounded-2xl border border-gray-100 dark:border-gray-800 overflow-hidden hover:border-gray-200 dark:hover:border-gray-700 flex flex-col relative"
>
  <a href={`/${post.id}/`} class="absolute inset-0 z-10" aria-label={title}></a>

  <div class="aspect-[2/1] bg-gray-100 dark:bg-gray-800 overflow-hidden flex-shrink-0">
    {
      cover ? (
        <img
          src={cover}
          alt={title}
          loading="lazy"
          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
        />
      ) : (
        <div class="w-full h-full bg-gradient-to-br from-[#f0faf5] to-[#e0f5ec] dark:from-[#42b883]/20 dark:to-[#35495e]/30 flex items-center justify-center">
          <span class="text-3xl font-bold text-[#42b883]/40 dark:text-[#65cfa0]/30 select-none">{title.charAt(0)}</span>
        </div>
      )
    }
  </div>

  <div class="p-5 flex flex-col flex-1">
    <div class="flex items-center gap-2 mb-2 text-xs text-gray-400 dark:text-gray-500">
      {category && <CategoryBadge category={category} />}
      <time datetime={date.toISOString()}>{formatDate(date)}</time>
      <span>·</span>
      <span>{readingTime(post.body ?? '')} 分鐘閱讀</span>
    </div>

    <h2
      class="text-lg font-semibold text-gray-900 dark:text-white group-hover:text-[#42b883] dark:group-hover:text-[#65cfa0] transition-colors leading-snug mb-2"
    >
      {title}
    </h2>

    {
      description && (
        <p class="text-gray-500 dark:text-gray-400 text-sm leading-relaxed line-clamp-2 flex-1">
          {stripMarkdown(description)}
        </p>
      )
    }

    {
      tags && tags.length > 0 && (
        <div class="flex flex-wrap gap-1.5 mt-3 relative z-20">
          {tags.slice(0, 4).map((tag) => (
            <a
              href={`/tags/${encodeURIComponent(tag)}/`}
              class="text-xs text-gray-400 dark:text-gray-500 hover:text-[#42b883] dark:hover:text-[#65cfa0] transition-colors"
            >
              #{tag}
            </a>
          ))}
        </div>
      )
    }
  </div>
</article>
