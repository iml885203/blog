---
interface Props {
  prevPost?: { id: string; data: { title: string } } | null;
  nextPost?: { id: string; data: { title: string } } | null;
}

import { Icon } from 'astro-icon/components';
import { getLangFromUrl, useTranslations, getLocalePath } from '@/i18n/utils';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const { prevPost, nextPost } = Astro.props;
---

<nav class="grid grid-cols-2 gap-4" aria-label={t('aria.postNav')}>
  <div>
    {
      nextPost && (
        <a
          href={getLocalePath(`/${nextPost.id}/`, lang)}
          class="group flex flex-col gap-1 rounded-xl border border-gray-200 dark:border-gray-800 p-4 hover:border-[#42b883] dark:hover:border-[#42b883] transition-colors"
        >
          <span class="text-xs text-gray-400 dark:text-gray-500 flex items-center gap-1">
            <Icon name="lucide:arrow-left" size={12} aria-hidden="true" />
            {t('post.prevPost')}
          </span>
          <span class="text-sm font-medium text-gray-700 dark:text-gray-300 group-hover:text-[#42b883] dark:group-hover:text-[#65cfa0] line-clamp-2 transition-colors leading-snug">
            {nextPost.data.title}
          </span>
        </a>
      )
    }
  </div>
  <div>
    {
      prevPost && (
        <a
          href={getLocalePath(`/${prevPost.id}/`, lang)}
          class="group flex flex-col gap-1 rounded-xl border border-gray-200 dark:border-gray-800 p-4 hover:border-[#42b883] dark:hover:border-[#42b883] transition-colors text-right"
        >
          <span class="text-xs text-gray-400 dark:text-gray-500 flex items-center gap-1 justify-end">
            {t('post.nextPost')}
            <Icon name="lucide:arrow-right" size={12} aria-hidden="true" />
          </span>
          <span class="text-sm font-medium text-gray-700 dark:text-gray-300 group-hover:text-[#42b883] dark:group-hover:text-[#65cfa0] line-clamp-2 transition-colors leading-snug">
            {prevPost.data.title}
          </span>
        </a>
      )
    }
  </div>
</nav>
